---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FlightSchoolCostCalculator from '@/components/tools/FlightSchoolCostCalculator.astro';

const title = 'Flight School Cost Calculator | Flight School Friend';
const description = 'Estimate private pilot, instrument, and career flight training costs with a beginner-friendly calculator built for people comparing flight school options.';
const canonical = 'https://flightschoolfriend.com/tools/flight-school-cost-calculator/';
const newsletterFormId = '9569637';
const newsletterFormAction = `https://app.kit.com/forms/${newsletterFormId}/subscriptions`;
const structuredData = {
  '@type': 'WebApplication',
  '@id': 'https://flightschoolfriend.com/tools/flight-school-cost-calculator/#webapp',
  name: 'Flight School Cost Calculator',
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  description,
  author: { '@id': 'https://flightschoolfriend.com/#person' },
};
---

<BaseLayout title={title} description={description} canonical={canonical} structuredData={structuredData}>
  <section class="px-4 pb-14">
    <FlightSchoolCostCalculator />
  </section>

  <section class="max-w-4xl mx-auto px-4 pb-10">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-extrabold uppercase tracking-widest text-sky-700">Real training cost notes</p>
        <h2 class="mt-2 text-2xl font-extrabold text-slate-950 md:text-3xl">Your estimate is a starting point</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600 md:text-base">
          Real training costs move with weather cancellations, plateau weeks, and how you schedule. Join the newsletter and I'll send you what training actually costs as I go through it: real invoices, real hours, no averages from 2019 blog posts.
        </p>
      </div>

      <form class="mx-auto mt-6 grid max-w-2xl gap-3 sm:grid-cols-[1fr_auto]" action={newsletterFormAction} method="post">
        <label class="sr-only" for="email-cost-newsletter">Email address</label>
        <input
          id="email-cost-newsletter"
          name="email_address"
          type="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-sm font-medium text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-sky-300 focus:ring-4 focus:ring-sky-300/25"
        />
        <input type="hidden" name="fields[source_page]" value="/tools/flight-school-cost-calculator/" />
        <input type="hidden" name="fields[lead_magnet]" value="flight_training_cost_newsletter" />
        <button
          type="submit"
          class="btn-hover h-12 rounded-lg bg-sky-600 px-5 text-sm font-extrabold text-white transition hover:bg-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-300/30"
        >
          Join the newsletter
        </button>
      </form>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 pb-20">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:flex md:items-center md:justify-between md:gap-6">
      <div class="max-w-xl">
        <p class="text-xs font-extrabold uppercase tracking-widest text-sky-700">Next decision</p>
        <h2 class="mt-2 text-2xl font-extrabold text-slate-950">Turn your estimate into a flight school plan.</h2>
        <p class="mt-2 text-slate-600">Use the decision tool to compare your budget, timeline, training path, and school-fit risks before you commit.</p>
      </div>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row md:mt-0 md:flex-col lg:flex-row">
        <a
          href="/flight-school-decision-tool/quiz/"
          class="btn-hover rounded-lg bg-sky-600 px-5 py-3 text-center text-sm font-extrabold text-white transition hover:bg-sky-500"
          data-cost-calculator-cta="cost_calculator_quiz_cta_click"
        >
          Take the Flight School Decision Quiz
        </a>
        <a
          href="/flight-school-decision-tool/"
          class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-center text-sm font-extrabold text-slate-800 transition hover:border-sky-300 hover:text-sky-700"
          data-cost-calculator-cta="cost_calculator_plan_cta_click"
        >
          Get the 28-Day Flight School Decision Plan
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
