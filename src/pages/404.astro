---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PrimaryCta from '@/components/PrimaryCta.astro';
---

<BaseLayout title="Page Not Found | PilotPath">
  <section class="mx-auto max-w-2xl px-4 py-24 text-center">
    <div class="mb-6 text-5xl">🛩️</div>
    <h1 class="mb-4 text-4xl font-extrabold text-slate-900">This page has left the pattern.</h1>
    <p class="mb-8 text-slate-600">Try the pilot path assessment or head back to the homepage.</p>
    <PrimaryCta href="/quiz/">Start the Assessment</PrimaryCta>
  </section>
</BaseLayout>
