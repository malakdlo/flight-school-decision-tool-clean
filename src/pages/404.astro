---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Flight School Friend">
  <section class="max-w-2xl mx-auto px-4 py-32 text-center">
    <div class="text-5xl mb-6">🛩️</div>
    <h1 class="text-3xl font-extrabold text-slate-900 mb-4">This page has left the pattern.</h1>
    <p class="text-slate-600 mb-8">Head back to the homepage or take the Flight School Decision Quiz.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-lg transition">&larr; Back to Homepage</a>
      <a href="/flight-school-decision-tool/quiz/" class="px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white font-bold rounded-lg transition">Start Here</a>
    </div>
  </section>
</BaseLayout>
