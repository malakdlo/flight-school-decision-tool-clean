---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ResultRoadmap from '@/components/ResultRoadmap.astro';
---

<BaseLayout title="Pilot Assessment | Flight School Decision Tool">
  <section id="quiz-intro" class="page-view active">
    <div class="mx-auto max-w-xl px-4 py-16">
      <div class="rounded-3xl border border-slate-100 bg-white p-8 text-center shadow-xl md:p-12">
        <div class="mx-auto mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-sky-100">
          <span class="text-3xl">📋</span>
        </div>
        <h1 class="mb-4 text-3xl font-extrabold text-slate-900">Assessment</h1>
        <h2 class="mb-6 text-xl font-medium text-slate-600">Is becoming a pilot actually realistic for you?</h2>
        <p class="mb-8 leading-relaxed text-slate-500">
          This interactive assessment estimates your best starting path based on your goals, budget, timeline, and concerns.
        </p>
        <div class="mb-10 space-y-4 text-left">
          <div class="flex items-center gap-3 text-sm text-slate-600"><span class="font-bold text-sky-500">✓</span> 6 targeted questions</div>
          <div class="flex items-center gap-3 text-sm text-slate-600"><span class="font-bold text-sky-500">✓</span> Personalized cost and time ranges</div>
          <div class="flex items-center gap-3 text-sm text-slate-600"><span class="font-bold text-sky-500">✓</span> Clear first steps</div>
        </div>
        <button id="start-quiz" class="btn-hover w-full rounded-xl bg-slate-900 py-4 font-bold text-white">Start Now (takes 2 mins)</button>
      </div>
    </div>
  </section>

  <section id="quiz-question" class="page-view">
    <div class="mx-auto max-w-2xl px-4 py-12">
      <div class="mb-12">
        <div class="mb-2 flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
          <span>Question <span id="q-index">1</span> of <span id="q-total">6</span></span>
          <span><span id="q-percent">16</span>% Complete</span>
        </div>
        <div class="h-2 overflow-hidden rounded-full bg-slate-200">
          <div id="q-progress-bar" class="h-full bg-sky-600 transition-all duration-500" style="width: 16%"></div>
        </div>
      </div>

      <div class="min-h-[400px]">
        <h2 id="question-text" class="mb-2 text-2xl font-bold text-slate-900 md:text-3xl"></h2>
        <p id="question-subtext" class="mb-10 italic text-slate-500"></p>
        <div id="options-container" class="space-y-4"></div>
      </div>

      <div class="mt-12 flex items-center justify-between">
        <button id="back-question" class="text-sm font-bold text-slate-400 hover:text-slate-900">Back</button>
        <button id="next-question" class="btn-hover rounded-lg bg-sky-600 px-8 py-3 font-bold text-white disabled:cursor-not-allowed disabled:opacity-40" disabled>Next</button>
      </div>
    </div>
  </section>

  <section id="quiz-loading" class="page-view">
    <div class="mx-auto max-w-md px-4 py-32 text-center">
      <div class="relative mx-auto mb-12 h-32 w-32">
        <div class="absolute inset-0 rounded-full border-4 border-sky-100"></div>
        <div class="absolute inset-0 animate-spin rounded-full border-4 border-sky-600 border-t-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-2xl">✈️</span>
        </div>
      </div>
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Analyzing your flight path...</h2>
      <div class="space-y-3 text-sm font-medium text-slate-400">
        <p class="loading-message opacity-0 transition-opacity duration-500">Cross-referencing training timelines...</p>
        <p class="loading-message opacity-0 transition-opacity duration-500">Calculating estimated investment costs...</p>
        <p class="loading-message opacity-0 transition-opacity duration-500">Preparing your personalized roadmap...</p>
      </div>
    </div>
  </section>

  <section id="results" class="page-view">
    <header class="border-b border-slate-200 bg-white py-16">
      <div class="mx-auto max-w-4xl px-4 text-center">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-amber-100 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-amber-700">
          <span>★</span> <span id="result-eyebrow">Your Recommended Path</span>
        </div>
        <h1 id="result-title" class="mb-6 text-4xl font-extrabold text-slate-900 md:text-5xl"></h1>
        <p id="result-desc" class="mx-auto max-w-2xl text-lg leading-relaxed text-slate-600"></p>
      </div>
    </header>

    <section class="mx-auto -mt-8 max-w-5xl px-4">
      <div id="result-stats" class="grid grid-cols-1 gap-4 md:grid-cols-3"></div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-20">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <div>
          <h3 class="mb-6 text-xl font-bold text-slate-900">Why this path fits:</h3>
          <div id="fit-reasons" class="space-y-4"></div>
        </div>
        <ResultRoadmap />
      </div>

      <div class="mt-20">
        <h3 class="mb-12 text-center text-2xl font-bold">Your First 3 Steps</h3>
        <div id="first-steps" class="space-y-6"></div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-20">
      <div class="relative overflow-hidden rounded-3xl bg-sky-600 p-10 text-center text-white">
        <div class="relative z-10">
          <h2 class="mb-4 text-3xl font-bold">Get the Full Roadmap (PDF)</h2>
          <p class="mx-auto mb-8 max-w-md text-sky-100">
            Get the full beginner starter kit with financing options, school questions, and discovery flight checklist.
          </p>
          <form class="mx-auto flex max-w-md flex-col gap-4 md:flex-row" data-starter-kit-form>
            <input type="email" required placeholder="Enter your email" class="flex-1 rounded-xl px-6 py-4 text-slate-900 focus:outline-none" />
            <button class="btn-hover rounded-xl bg-slate-900 px-8 py-4 font-bold">Send My Kit</button>
          </form>
          <p class="mt-3 text-xs text-sky-100">Form provider not connected yet. V1 placeholder.</p>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { quizQuestions } from '@/data/quizQuestions';
  import { resultPaths } from '@/data/results';
  import { scoreQuiz } from '@/lib/scoring';
  import type { QuizAnswer, ResultType } from '@/types/quiz';

  const views = {
    intro: document.getElementById('quiz-intro'),
    question: document.getElementById('quiz-question'),
    loading: document.getElementById('quiz-loading'),
    results: document.getElementById('results'),
  };

  const state: {
    currentQuestion: number;
    answers: QuizAnswer[];
    selectedOptionId: string | null;
  } = {
    currentQuestion: 0,
    answers: [],
    selectedOptionId: null,
  };

  const qIndex = document.getElementById('q-index');
  const qTotal = document.getElementById('q-total');
  const qPercent = document.getElementById('q-percent');
  const qProgressBar = document.getElementById('q-progress-bar');
  const questionText = document.getElementById('question-text');
  const questionSubtext = document.getElementById('question-subtext');
  const optionsContainer = document.getElementById('options-container');
  const nextButton = document.getElementById('next-question') as HTMLButtonElement;

  function showView(viewName: keyof typeof views) {
    Object.values(views).forEach((view) => view?.classList.remove('active'));
    views[viewName]?.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderQuestion() {
    const question = quizQuestions[state.currentQuestion];
    const existingAnswer = state.answers.find((answer) => answer.questionId === question.id);
    state.selectedOptionId = existingAnswer?.optionId ?? null;

    const progress = Math.round(((state.currentQuestion + 1) / quizQuestions.length) * 100);

    if (qIndex) qIndex.textContent = String(state.currentQuestion + 1);
    if (qTotal) qTotal.textContent = String(quizQuestions.length);
    if (qPercent) qPercent.textContent = String(progress);
    if (qProgressBar) qProgressBar.style.width = `${progress}%`;
    if (questionText) questionText.textContent = question.question;
    if (questionSubtext) questionSubtext.textContent = question.subtext;

    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    question.options.forEach((option) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'quiz-option w-full rounded-xl border border-slate-100 bg-white p-5 text-left font-semibold text-slate-700 shadow-sm hover:border-sky-300 hover:bg-sky-50';
      button.textContent = option.label;
      button.setAttribute('aria-pressed', String(option.id === state.selectedOptionId));

      button.addEventListener('click', () => {
        state.selectedOptionId = option.id;
        nextButton.disabled = false;
        optionsContainer.querySelectorAll('button').forEach((item) => item.setAttribute('aria-pressed', 'false'));
        button.setAttribute('aria-pressed', 'true');
      });

      optionsContainer.appendChild(button);
    });

    nextButton.disabled = !state.selectedOptionId;
  }

  function saveAnswer() {
    const question = quizQuestions[state.currentQuestion];
    if (!state.selectedOptionId) return;

    state.answers = state.answers.filter((answer) => answer.questionId !== question.id);
    state.answers.push({ questionId: question.id, optionId: state.selectedOptionId });
  }

  function renderResult(resultType: ResultType) {
    const result = resultPaths[resultType];

    document.getElementById('result-eyebrow')!.textContent = result.eyebrow;
    document.getElementById('result-title')!.textContent = result.title;
    document.getElementById('result-desc')!.textContent = result.description;

    const statsContainer = document.getElementById('result-stats')!;
    statsContainer.innerHTML = result.stats
      .map((stat) => {
        const isDark = stat.variant === 'dark';
        return `
          <div class="rounded-2xl border ${isDark ? 'border-slate-800 bg-slate-900 text-white' : 'border-slate-100 bg-white text-slate-900'} p-6 shadow-lg">
            <div class="mb-2 text-xs font-bold uppercase tracking-wider ${isDark ? 'text-slate-400' : 'text-slate-400'}">${stat.label}</div>
            <div class="text-2xl font-bold ${isDark ? 'text-sky-400' : 'text-slate-900'}">${stat.value}</div>
            <div class="mt-1 text-xs ${isDark ? 'text-slate-500' : 'text-slate-500'}">${stat.note}</div>
          </div>
        `;
      })
      .join('');

    const fitReasons = document.getElementById('fit-reasons')!;
    fitReasons.innerHTML = result.fitReasons
      .map((reason) => `<div class="flex gap-3"><span class="font-bold text-sky-600">✓</span><p class="text-sm text-slate-600">${reason}</p></div>`)
      .join('');

    const firstSteps = document.getElementById('first-steps')!;
    firstSteps.innerHTML = result.firstSteps
      .map(
        (step, index) => `
          <article class="flex flex-col gap-6 rounded-2xl border border-slate-100 bg-white p-8 md:flex-row">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full ${index === 0 ? 'bg-sky-600' : 'bg-slate-900'} font-bold text-white">${index + 1}</div>
            <div>
              <h4 class="mb-2 text-lg font-bold">${step.title}</h4>
              <p class="text-sm text-slate-500">${step.description}</p>
              ${step.href && step.linkLabel ? `<a href="${step.href}" class="mt-4 inline-block text-sm font-bold text-sky-600 hover:underline">${step.linkLabel} →</a>` : ''}
            </div>
          </article>
        `,
      )
      .join('');
  }

  function runLoading() {
    showView('loading');
    document.querySelectorAll('.loading-message').forEach((message, index) => {
      setTimeout(() => message.classList.add('opacity-100'), 650 * (index + 1));
    });

    window.setTimeout(() => {
      const resultType = scoreQuiz(state.answers);
      renderResult(resultType);
      showView('results');
    }, 2600);
  }

  document.getElementById('start-quiz')?.addEventListener('click', () => {
    state.currentQuestion = 0;
    state.answers = [];
    state.selectedOptionId = null;
    renderQuestion();
    showView('question');
  });

  document.getElementById('back-question')?.addEventListener('click', () => {
    if (state.currentQuestion === 0) {
      showView('intro');
      return;
    }

    state.currentQuestion -= 1;
    renderQuestion();
  });

  nextButton?.addEventListener('click', () => {
    saveAnswer();

    if (state.currentQuestion < quizQuestions.length - 1) {
      state.currentQuestion += 1;
      renderQuestion();
      return;
    }

    runLoading();
  });
</script>
