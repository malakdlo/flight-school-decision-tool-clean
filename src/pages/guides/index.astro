---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GuideAudienceLinks from '@/components/GuideAudienceLinks.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const guideCards = guides.map(({ data }) =>
  data.href === '/guides/pre-solo-written/'
    ? {
        ...data,
        title: 'The Pre-Solo Written & Oral Review',
        description:
          'What FAR 61.87(b) requires, what to gather from your POH and Chart Supplement, a 26-question practice bank, and what your CFI is listening for.',
      }
    : data
);
---

<BaseLayout
  title="Flight School Starter Guides | Flight School Friend"
  description="Beginner-friendly flight school guides covering costs, training paths, requirements, and how to choose a school."
>
  <section class="max-w-6xl mx-auto px-4 py-20 text-center">
    <span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full mb-6 tracking-widest uppercase border border-slate-200">
      Aviation Education Hub
    </span>
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Flight School Starter Guides</h1>
    <p class="text-xl text-slate-600 mb-4 max-w-3xl mx-auto leading-relaxed">
      Clear, beginner-friendly guides to help you understand flight school cost, training paths, requirements, and how to choose a school before you spend heavily.
    </p>
    <p class="text-slate-500 mb-10 max-w-2xl mx-auto">
      Start with the topic that matches your biggest question, or take the Flight School Decision Tool for a personalized starting path.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/flight-school-decision-tool/quiz/" class="w-full sm:w-auto px-8 py-4 bg-sky-600 text-white font-bold rounded-xl text-lg btn-hover shadow-md">
        Start Here
      </a>
      <a href="/flight-school-decision-tool/" class="w-full sm:w-auto px-8 py-4 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl text-lg btn-hover shadow-sm">
        How the Decision Tool Works
      </a>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-24">
    <div class="mb-8">
      <GuideAudienceLinks />
    </div>

    {
      guideCards.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {guideCards.map((guide) => (
            <a href={guide.href} class="group block bg-slate-50 border border-slate-200 hover:border-sky-300 rounded-2xl p-8 transition shadow-sm hover:shadow-md">
              <span class={`inline-block ${guide.categoryClasses} text-xs font-bold px-3 py-1 rounded-full mb-4`}>{guide.category}</span>
              <h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-sky-700 transition">{guide.title}</h2>
              <p class="text-slate-600 mb-6">{guide.description}</p>
              <span class="text-sky-600 font-bold uppercase text-sm tracking-wider">Read Guide &rarr;</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-slate-600">First guides landing here soon &mdash; the newsletter hears first.</p>
      )
    }

    <div class="mt-16 bg-slate-900 text-white rounded-3xl p-10 md:p-16 text-center">
      <h2 class="text-3xl font-bold mb-4">Not sure which guide fits your situation?</h2>
      <p class="text-slate-400 max-w-2xl mx-auto mb-8 text-lg">Take the Flight School Decision Tool and get a starting roadmap based on your goals, budget, timeline, medical readiness, and training preferences.</p>
      <a href="/flight-school-decision-tool/quiz/" class="inline-block px-8 py-4 bg-sky-600 hover:bg-sky-500 font-bold rounded-xl text-lg transition shadow-md">
        Start Here
      </a>
    </div>
  </section>
</BaseLayout>
