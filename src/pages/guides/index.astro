---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const guideCards = guides.map(({ data }) =>
  data.href === '/guides/pre-solo-written/'
    ? {
        ...data,
        title: 'The Pre-Solo Written & Oral Review',
        description:
          'What FAR 61.87(b) requires, what to gather from your POH and Chart Supplement, a 26-question practice bank, and what your CFI is listening for.',
      }
    : data
);
const topics = [...new Set(guideCards.map((guide) => guide.category))];
const stageLabels: Record<string, string> = {
  researching: 'Research',
  'ppl-student': 'PPL student',
  both: 'Both stages',
};
---

<BaseLayout
  title="Flight School Starter Guides | Flight School Friend"
  description="Beginner-friendly flight school guides covering costs, training paths, requirements, and how to choose a school."
>
  <section class="max-w-6xl mx-auto px-4 py-20 text-center">
    <span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full mb-6 tracking-widest uppercase border border-slate-200">
      Aviation Education Hub
    </span>
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Flight School Starter Guides</h1>
    <p class="text-xl text-slate-600 mb-4 max-w-3xl mx-auto leading-relaxed">
      Clear, beginner-friendly guides to help you understand flight school cost, training paths, requirements, and how to choose a school before you spend heavily.
    </p>
    <p class="text-slate-500 max-w-2xl mx-auto">
      Start with the stage and topic that match your biggest question right now.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-24">
    <div class="mb-8 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm md:p-5">
      <div class="grid gap-5">
        <div class="grid gap-3 md:grid-cols-[6rem_1fr] md:items-center">
          <p class="font-mono text-xs font-bold uppercase tracking-widest text-slate-500">Stage</p>
          <div class="flex flex-wrap gap-2" aria-label="Filter guides by stage">
            <button type="button" class="guide-filter rounded-full border border-sky-600 bg-sky-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-300/30" data-filter-type="stage" data-filter-value="all" aria-pressed="true">All stages</button>
            <button type="button" class="guide-filter rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-sky-300 hover:bg-sky-50 focus:outline-none focus:ring-4 focus:ring-sky-300/30" data-filter-type="stage" data-filter-value="researching" aria-pressed="false">Research</button>
            <button type="button" class="guide-filter rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-sky-300 hover:bg-sky-50 focus:outline-none focus:ring-4 focus:ring-sky-300/30" data-filter-type="stage" data-filter-value="ppl-student" aria-pressed="false">PPL student</button>
          </div>
        </div>

        <div class="grid gap-3 md:grid-cols-[6rem_1fr] md:items-center">
          <p class="font-mono text-xs font-bold uppercase tracking-widest text-slate-500">Topic</p>
          <div class="flex flex-wrap gap-2" aria-label="Filter guides by topic">
            <button type="button" class="guide-filter rounded-full border border-sky-600 bg-sky-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-300/30" data-filter-type="topic" data-filter-value="all" aria-pressed="true">All topics</button>
            {topics.map((topic) => (
              <button type="button" class="guide-filter rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-sky-300 hover:bg-sky-50 focus:outline-none focus:ring-4 focus:ring-sky-300/30" data-filter-type="topic" data-filter-value={topic} aria-pressed="false">{topic}</button>
            ))}
          </div>
        </div>
      </div>
    </div>

    {
      guideCards.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-guide-grid>
          {guideCards.map((guide) => (
            <a href={guide.href} class="group block bg-slate-50 border border-slate-200 hover:border-sky-300 rounded-2xl p-8 transition shadow-sm hover:shadow-md" data-guide-card data-stage={guide.audience} data-topic={guide.category}>
              <div class="mb-4 flex flex-wrap gap-2">
                <span class={`inline-block ${guide.categoryClasses} text-xs font-bold px-3 py-1 rounded-full`}>{guide.category}</span>
                <span class="inline-block rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-bold text-slate-600">{stageLabels[guide.audience] ?? 'Guide'}</span>
              </div>
              <h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-sky-700 transition">{guide.title}</h2>
              <p class="text-slate-600 mb-6">{guide.description}</p>
              <span class="text-sky-600 font-bold uppercase text-sm tracking-wider">Read Guide &rarr;</span>
            </a>
          ))}
          <p class="hidden rounded-2xl border border-dashed border-slate-300 bg-white p-6 text-sm leading-6 text-slate-600 md:col-span-2" data-guide-empty>
            No guides match those filters yet.
          </p>
        </div>
      ) : (
        <p class="text-slate-600">First guides landing here soon &mdash; the newsletter hears first.</p>
      )
    }
  </section>

  <script>
    const activeClasses = ['border-sky-600', 'bg-sky-600', 'text-white', 'hover:bg-sky-700'];
    const inactiveClasses = ['border-slate-200', 'bg-white', 'text-slate-700', 'hover:border-sky-300', 'hover:bg-sky-50'];
    const filters = {
      stage: 'all',
      topic: 'all',
    };

    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.guide-filter'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-guide-card]'));
    const emptyState = document.querySelector<HTMLElement>('[data-guide-empty]');

    const setButtonState = (button: HTMLButtonElement, isActive: boolean) => {
      button.setAttribute('aria-pressed', String(isActive));
      button.classList.remove(...(isActive ? inactiveClasses : activeClasses));
      button.classList.add(...(isActive ? activeClasses : inactiveClasses));
    };

    const applyFilters = () => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const stage = card.dataset.stage ?? '';
        const topic = card.dataset.topic ?? '';
        const stageMatches = filters.stage === 'all' || stage === filters.stage || stage === 'both';
        const topicMatches = filters.topic === 'all' || topic === filters.topic;
        const isVisible = stageMatches && topicMatches;

        card.classList.toggle('hidden', !isVisible);
        if (isVisible) visibleCount += 1;
      });

      emptyState?.classList.toggle('hidden', visibleCount > 0);
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const type = button.dataset.filterType as 'stage' | 'topic';
        const value = button.dataset.filterValue ?? 'all';

        filters[type] = value;
        buttons
          .filter((candidate) => candidate.dataset.filterType === type)
          .forEach((candidate) => setButtonState(candidate, candidate === button));
        applyFilters();
      });
    });
  </script>
</BaseLayout>
