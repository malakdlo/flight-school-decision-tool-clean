---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StatusBadge from '@/components/StatusBadge.astro';
---

<BaseLayout
  title="Researching Flight School — Flight School Friend"
  description="Start deciding on flight school with free tools, calculators, guides, and the 28-day decision program."
>
  <section class="mx-auto max-w-6xl px-4 py-20 md:py-28">
    <span class="mb-5 inline-block rounded-full bg-sky-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-sky-800">Researching Flight School</span>
    <h1 class="mb-5 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">Deciding on flight school starts here.</h1>
    <p class="max-w-2xl text-lg leading-8 text-slate-600">Use these tools and guides to compare paths, estimate training costs, and decide what to do before you spend a dollar on lessons.</p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-24">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <a href="/flight-school-decision-tool/quiz/" class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-300">
        <StatusBadge status="live" />
        <h2 class="mt-4 mb-2 text-xl font-bold text-slate-900">Decision Quiz</h2>
        <p class="text-sm leading-6 text-slate-600">Find the starting path that best fits your goal, schedule, budget, timeline, and readiness.</p>
      </a>

      <a href="/tools/flight-school-cost-calculator/" class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-300">
        <StatusBadge status="live" />
        <h2 class="mt-4 mb-2 text-xl font-bold text-slate-900">Cost Calculator</h2>
        <p class="text-sm leading-6 text-slate-600">Estimate low, realistic, and high training cost ranges using local aircraft and instructor rates.</p>
      </a>

      <a href="/guides/" class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-300">
        <StatusBadge status="live" />
        <h2 class="mt-4 mb-2 text-xl font-bold text-slate-900">Flight School Research Guides</h2>
        <p class="text-sm leading-6 text-slate-600">Read practical guides on cost, Part 61 vs Part 141, school fit, and private pilot requirements.</p>
      </a>

      <a href="/tools/28-day-research-tracker/" class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-300">
        <StatusBadge status="live" />
        <h2 class="mt-4 mb-2 text-xl font-bold text-slate-900">28-Day Research Tracker</h2>
        <p class="text-sm leading-6 text-slate-600">A four-week Google Sheet that turns "should I do this?" into a researched decision. Free.</p>
      </a>
    </div>
  </section>
</BaseLayout>
