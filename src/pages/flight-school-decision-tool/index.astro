---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Flight School Decision Tool | Flight School Friend"
  description="Answer practical questions and get a recommended flight training starting path based on your goal, budget, schedule, and readiness."
>
  <section class="max-w-4xl mx-auto px-4 py-20 text-center">
    <span class="inline-block px-3 py-1 bg-sky-100 text-sky-800 text-xs font-bold rounded-full mb-6 tracking-widest uppercase">Interactive Tool</span>
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Flight School Decision Tool</h1>
    <p class="text-xl text-slate-600 mb-10 leading-relaxed max-w-3xl mx-auto">
      Answer a few practical questions and get a recommended starting path based on your goal, budget, timeline, schedule, medical readiness, and confidence level.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/flight-school-decision-tool/quiz/" class="w-full sm:w-auto px-8 py-4 bg-sky-600 text-white font-bold rounded-xl text-lg btn-hover shadow-md">
        Start the Quiz
      </a>
      <a href="/guides/" class="w-full sm:w-auto px-8 py-4 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl text-lg btn-hover shadow-sm">
        Read the Guides
      </a>
    </div>
  </section>

  <section class="bg-white py-20 border-y border-slate-200">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="text-2xl font-bold text-slate-900 mb-6">What this tool helps you decide</h2>
        <ul class="space-y-4 text-slate-600">
          <li class="flex gap-3"><span class="text-sky-500 font-bold">✓</span> Whether to start with a flexible PPL path, career training plan, ownership/travel path, or research checklist.</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">✓</span> What to clarify before calling schools.</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">✓</span> Which guides and tools to read next.</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">✓</span> Whether your next step should be a discovery flight, medical research, cost planning, or school comparison.</li>
        </ul>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-slate-900 mb-6">What the quiz asks</h2>
        <div class="flex flex-wrap gap-2">
          {['Your goal','Timeline','Weekly availability','Budget comfort','Medical readiness','Learning style','Confidence level','School-contact readiness'].map(tag => (
            <span class="bg-slate-100 text-slate-700 px-3 py-1.5 rounded-lg text-sm font-medium">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 max-w-6xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold text-slate-900 mb-12">What you get</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-16">
      {['Result type','Custom roadmap','Watch-outs','Recommended next steps','Email capture','Related guides/tools'].map(item => (
        <div class="bg-white p-4 border border-slate-200 rounded-xl shadow-sm text-sm font-bold text-slate-700">{item}</div>
      ))}
    </div>
    <a href="/flight-school-decision-tool/quiz/" class="inline-block px-8 py-4 bg-sky-600 text-white font-bold rounded-xl text-lg btn-hover shadow-md">
      Start the Quiz
    </a>
  </section>
</BaseLayout>
