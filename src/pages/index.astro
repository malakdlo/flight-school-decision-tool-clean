---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FounderNote from '@/components/FounderNote.astro';
import KitCapture from '@/components/KitCapture.astro';
import { getCollection } from 'astro:content';

const postPath = (post: { id: string; slug?: string }) => `/journey/${post.slug ?? post.id.replace(/\.mdx?$/, '')}/`;
const journeyPosts = (await getCollection('journey', ({ data }) => !data.draft))
  .filter((post) => post.data.stage === 'ppl')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Flight School Friend — Free Flight School Tools, Built by a Student Pilot"
  description="Free flight school tools, calculators, and PPL checklists built in public by a student pilot documenting every flight."
>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-4 py-20 md:py-28">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="mb-6 inline-block rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-slate-700">
          Free tools for future pilots — built by a student pilot, in public
        </span>
        <h1 class="mb-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 md:text-5xl">
          Figure out flight school with someone who's actually in it.
        </h1>
        <p class="mb-8 max-w-xl text-lg leading-relaxed text-slate-600">
          Flight School Friend gives you free tools, calculators, and checklists to decide if flight training fits your life — built and tested by a student pilot working through PPL training right now.
        </p>
        <div class="mb-3 flex flex-col items-center gap-4 sm:flex-row">
          <a href="/flight-school-decision-tool/quiz/" class="btn-hover w-full rounded-xl bg-sky-600 px-8 py-4 text-center text-lg font-bold text-white shadow-md sm:w-auto">
            Find your starting path →
          </a>
          <a href="/tools/flight-school-cost-calculator/" class="btn-hover w-full rounded-xl border border-slate-200 bg-white px-8 py-4 text-center text-lg font-bold text-slate-700 shadow-sm sm:w-auto">
            Estimate your training costs
          </a>
        </div>
        <p class="text-xs font-medium text-slate-500">Free 3-minute quiz. No email required to see your result. No school sales calls.</p>
      </div>

      <!-- Hero Visual -->
      <div class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-8 shadow-xl">
        <div class="absolute right-0 top-0 -z-10 h-32 w-32 rounded-bl-full bg-sky-50"></div>
        <h3 class="mb-6 border-b border-slate-100 pb-4 text-sm font-bold uppercase tracking-widest text-slate-900">Decision Factors</h3>
        <div class="mb-8 space-y-4">
          <div class="flex items-center justify-between gap-4"><span class="text-slate-500">Goal</span><span class="rounded-md bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-900">Career Airlines</span></div>
          <div class="flex items-center justify-between gap-4"><span class="text-slate-500">Budget</span><span class="rounded-md bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-900">Financing Needed</span></div>
          <div class="flex items-center justify-between gap-4"><span class="text-slate-500">Timeline</span><span class="rounded-md bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-900">Fast-Track</span></div>
          <div class="flex items-center justify-between gap-4"><span class="text-slate-500">Medical</span><span class="rounded-md bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-900">First Class Req.</span></div>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900 p-5 text-white">
          <div class="mb-1 text-xs font-bold uppercase tracking-wider text-sky-400">Recommended Path</div>
          <div class="text-xl font-bold">Career Captain</div>
        </div>
      </div>
    </div>
  </section>

  <FounderNote />

  <!-- Problem Section -->
  <section class="bg-slate-900 py-24 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mb-16 max-w-3xl">
        <h2 class="mb-6 text-3xl font-bold tracking-tight md:text-4xl">Flight school is exciting — but the first decision is harder than it looks.</h2>
        <p class="text-lg leading-relaxed text-slate-400">
          Most future pilots are not just asking "Which school should I call?" They are trying to understand whether aviation fits their budget, schedule, health/medical readiness, career goals, and confidence level.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
          <h3 class="mb-2 text-xl font-bold text-sky-400">Costs vary quickly</h3>
          <p class="text-sm text-slate-300">Aircraft rates, instructor rates, pace, and total hours can change the real cost.</p>
        </div>
        <div class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
          <h3 class="mb-2 text-xl font-bold text-sky-400">Training paths are confusing</h3>
          <p class="text-sm text-slate-300">Part 61, Part 141, accelerated programs, clubs, and academies all fit different students.</p>
        </div>
        <div class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
          <h3 class="mb-2 text-xl font-bold text-sky-400">Medical questions matter early</h3>
          <p class="text-sm text-slate-300">Some students should clarify medical readiness before spending heavily.</p>
        </div>
        <div class="rounded-2xl border border-slate-700 bg-slate-800 p-6">
          <h3 class="mb-2 text-xl font-bold text-sky-400">Your goal changes the plan</h3>
          <p class="text-sm text-slate-300">A hobby pilot, career switcher, and future aircraft owner should not follow the same roadmap.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How Flight School Friend Helps -->
  <section class="mx-auto max-w-6xl px-4 py-24 text-center">
    <h2 class="mb-16 text-3xl font-bold tracking-tight text-slate-900">A better starting point before you commit.</h2>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
      <div>
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-sky-100 text-2xl font-bold text-sky-600">1</div>
        <h3 class="mb-3 text-xl font-bold text-slate-900">Take the decision quiz</h3>
        <p class="text-sm text-slate-600">Answer practical questions about your goal, budget, schedule, timeline, and readiness.</p>
      </div>
      <div>
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-sky-100 text-2xl font-bold text-sky-600">2</div>
        <h3 class="mb-3 text-xl font-bold text-slate-900">Get a starting roadmap</h3>
        <p class="text-sm text-slate-600">See whether you look more like a Weekend Hobbyist, Career Captain, Personal Owner, or Research-First planner.</p>
      </div>
      <div>
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-sky-100 text-2xl font-bold text-sky-600">3</div>
        <h3 class="mb-3 text-xl font-bold text-slate-900">Use guides and tools</h3>
        <p class="text-sm text-slate-600">Compare schools, estimate costs, and prepare better questions before booking or paying.</p>
      </div>
    </div>
  </section>

  <!-- Quiz Preview & Four Paths -->
  <section class="border-y border-slate-200 bg-white py-24">
    <div class="mx-auto grid max-w-6xl grid-cols-1 items-start gap-16 px-4 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2 class="mb-6 text-3xl font-bold tracking-tight text-slate-900">Get a recommended starting path in a few minutes.</h2>
        <p class="mb-6 text-slate-600">The quiz looks at:</p>
        <ul class="mb-8 space-y-3 text-sm font-medium text-slate-700">
          {[
            'Why you want to fly',
            'Whether you are career, hobby, travel, ownership, or research-first motivated',
            'How much time you can train each week',
            'How soon you want to make progress',
            'Budget comfort',
            'Medical/document readiness',
            'Confidence level',
            'Whether you are ready to contact schools',
          ].map((item) => (
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 flex-shrink-0 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/flight-school-decision-tool/quiz/" class="btn-hover inline-block rounded-xl bg-sky-600 px-8 py-4 text-lg font-bold text-white shadow-md">
          Start Here
        </a>
      </div>
      <div class="lg:col-span-7">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Four possible starting paths</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {[
            ['Weekend Hobbyist', 'You may fit a flexible local PPL path focused on fun, skill-building, and sustainable weekly training.'],
            ['Career Captain', 'You may need a structured, cost-aware training plan that looks beyond PPL toward instrument, commercial, CFI, and hour building.'],
            ['Personal Owner', 'You may be best served by PPL first, then cross-country confidence, instrument training, and ownership/club research.'],
            ['Research-First', 'You may need to clarify cost, medical readiness, and school fit before spending heavily.'],
          ].map(([title, text]) => (
            <div class:list={['rounded-2xl border border-slate-200 bg-slate-50 p-6', title === 'Research-First' && 'border-l-4 border-l-amber-400']}>
              <h4 class="mb-2 font-bold text-slate-900">{title}</h4>
              <p class="mb-4 text-sm text-slate-600">{text}</p>
              <a href="/flight-school-decision-tool/quiz/" class="text-sm font-semibold text-sky-600 hover:underline">Take the quiz to see if this fits →</a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Cost calculator feature -->
  <section class="mx-auto max-w-6xl px-4 py-24">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-xl">
        <div class="rounded-2xl bg-slate-50 p-5">
          <div class="mb-4 flex items-center justify-between border-b border-slate-200 pb-4">
            <span class="text-xs font-bold uppercase tracking-widest text-slate-500">Training Cost Range</span>
            <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-bold text-green-800">Live tool</span>
          </div>
          <div class="space-y-3">
            <div class="rounded-xl border border-slate-200 bg-white p-4">
              <div class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-400">Low</div>
              <div class="text-2xl font-extrabold text-slate-900">$12,800</div>
            </div>
            <div class="rounded-xl border-2 border-sky-300 bg-white p-4">
              <div class="mb-1 text-xs font-bold uppercase tracking-wider text-sky-600">Realistic</div>
              <div class="text-3xl font-extrabold text-slate-900">$18,950</div>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4">
              <div class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-400">High</div>
              <div class="text-2xl font-extrabold text-slate-900">$25,400</div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <h2 class="mb-5 text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">Know the real number before you call a school</h2>
        <p class="mb-7 text-lg leading-8 text-slate-600">Estimate a low / realistic / high training cost range based on your local rates and path — so quotes make sense and surprises don't derail you.</p>
        <a href="/tools/flight-school-cost-calculator/" class="btn-hover inline-block rounded-xl bg-slate-900 px-8 py-4 text-lg font-bold text-white shadow-md">
          Run your numbers →
        </a>
      </div>
    </div>
  </section>

  <!-- Journey preview -->
  <section class="border-y border-slate-200 bg-slate-50 py-24">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mb-10 max-w-3xl">
        <h2 class="mb-4 text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">The journey, flight by flight</h2>
        <p class="text-lg leading-8 text-slate-600">Every lesson gets a logbook entry — what happened, what I got wrong, and what I'd tell someone one flight behind me.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {journeyPosts.map((post) => (
          <a href={postPath(post)} class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-300">
            <p class="mb-3 text-xs font-bold uppercase tracking-widest text-slate-500">Flight {post.data.flightNumber} · {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
            <h3 class="mb-2 text-lg font-bold text-slate-900">{post.data.title}</h3>
            <p class="mb-4 text-sm text-slate-600">{post.data.summary}</p>
            {post.data.hoursThisFlight && <p class="text-xs font-bold uppercase tracking-widest text-sky-700">{post.data.hoursThisFlight} hrs</p>}
          </a>
        ))}
      </div>
      <a href="/journey/" class="mt-8 inline-block text-sm font-bold text-sky-700 hover:underline">Read the full journey →</a>
    </div>
  </section>

  <!-- 28-Day Plan capture -->
  <section class="mx-auto max-w-6xl px-4 py-24">
    <KitCapture
      id="home-28-day-program"
      heading="Turn your research into a decision."
      body="Get the free 28-Day Flight School Decision Program — a day-by-day framework for figuring out whether flight training is right for you, before you spend a dollar on lessons."
      buttonLabel="Send me the program"
      microcopy="Free. One email with the PDF, then occasional new tools and guides. Unsubscribe anytime."
      hiddenFields={[
        { name: 'fields[source_page]', dynamic: 'source_page' },
        { name: 'fields[utm_source]', dynamic: 'utm_source' },
        { name: 'fields[utm_medium]', dynamic: 'utm_medium' },
        { name: 'fields[utm_campaign]', dynamic: 'utm_campaign' },
      ]}
    />
  </section>

  <section class="bg-white py-12 text-center text-sm text-slate-500">
    <p class="mx-auto max-w-3xl px-4">Flight School Friend is independent decision support. It is not flight instruction, legal, medical, financial, or FAA certification advice. Always verify requirements with the FAA, your aviation medical examiner, and your flight school.</p>
  </section>
</BaseLayout>
