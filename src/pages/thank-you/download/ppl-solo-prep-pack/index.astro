---
import FounderNote from '@/components/FounderNote.astro';
import DownloadLayout from '@/layouts/DownloadLayout.astro';
---

<DownloadLayout
  title="Your PPL Solo Prep Pack is ready"
  description="Your private access page for the PPL Solo Prep Pack sheets and study guide."
>
  <section class="mx-auto max-w-4xl px-4 py-14 sm:py-20">
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:p-10">
      <p class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-sky-700">Download access</p>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-950 sm:text-5xl">
        Your PPL Solo Prep Pack is ready 🛫
      </h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        Everything below is yours. The sheets open as "make a copy" links — save them to your own Google Drive and they're yours to edit.
      </p>
    </div>
  </section>

  <FounderNote
    headline="A quick note from Malak"
    body="These are the exact sheets I'm using for my own solo prep at KRVS — not templates I made for other people. If something's confusing or missing, reply to any email and tell me. — Malak"
    showLinks={false}
  />

  <section class="mx-auto max-w-4xl px-4 py-12 sm:py-16">
    <div class="space-y-12">
      <section aria-labelledby="sheets-heading">
        <h2 id="sheets-heading" class="text-2xl font-extrabold text-slate-950 sm:text-3xl">Sheets</h2>
        <div class="mt-6 grid gap-5">
          <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-bold text-slate-950">PPL Solo — Flight Tracker Sheet</h3>
            <a
              href="https://docs.google.com/spreadsheets/d/1Ah-syQMrO3bs8UKw_kNDitmIWkMuLUFJ-P-IDP680bw/copy?usp=sharing"
              target="_blank"
              rel="noopener"
              class="mt-3 inline-flex rounded-lg bg-sky-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-sky-800"
            >
              Make your copy →
            </a>
            <p class="mt-4 leading-7 text-slate-600">
              Track everything between you and your first solo: a Dashboard overview, a §61.87(d) requirements tracker, a flight lesson log, a solo requirements checklist, and a topic reference tab.
            </p>
          </article>

          <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-bold text-slate-950">PPL Solo — Pre-Solo Study Questions</h3>
            <a
              href="https://docs.google.com/spreadsheets/d/1f5zg6kDxsz65goElmGFa3MNmh-ScBSaYF9LV4wHxAr0/copy?usp=sharing"
              target="_blank"
              rel="noopener"
              class="mt-3 inline-flex rounded-lg bg-sky-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-sky-800"
            >
              Make your copy →
            </a>
            <p class="mt-4 leading-7 text-slate-600">
              The pre-solo written, organized: a flight cheat sheet tab, a written study table, and a sources & notes tab so every answer traces back to the FAR/AIM or your POH.
            </p>
          </article>
        </div>
      </section>

      <section aria-labelledby="docs-heading">
        <h2 id="docs-heading" class="text-2xl font-extrabold text-slate-950 sm:text-3xl">Docs</h2>
        <article class="mt-6 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-xl font-bold text-slate-950">
            PPL Solo — Study Guide
            <span class="block text-base font-semibold leading-7 text-slate-600">
              chair flying guide, checklists, cheat sheets, and Claude prompts
            </span>
          </h3>
          <a
            href="https://flightschoolfriend.com/journey/how-im-studying-pre-solo/"
            class="mt-3 inline-flex rounded-lg bg-slate-900 px-4 py-2 text-sm font-bold text-white transition hover:bg-slate-800"
          >
            Read it here →
          </a>
          <p class="mt-4 leading-7 text-slate-600">
            This one currently lives as a journey post — the downloadable doc version is in the works, and you'll get an email when it ships.
          </p>
        </article>
      </section>

      <p class="border-t border-slate-200 pt-8 text-lg font-bold text-slate-950">
        Bookmark this page — it's your permanent access link.
      </p>
    </div>
  </section>
</DownloadLayout>
