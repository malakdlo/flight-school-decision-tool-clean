<section class="fsf-flightcomp" aria-labelledby="fc-heading">
  <div class="fc-shell">
    <header class="fc-hero">
      <div class="hero-copy">
        <p class="eyebrow">Flight planning practice</p>
        <h1 id="fc-heading">Flight computer practice trainer</h1>
        <p class="lead">
          The calculations you spin through on a manual E6B-style flight computer — wind triangles, time-speed-distance, fuel,
          density altitude — worked digitally so you can build speed and intuition between lessons. Every result shows the
          formula behind it.
        </p>
      </div>

      <aside class="mode-card" aria-label="Trainer modes">
        <p class="eyebrow">Modes</p>
        <div class="mode-tabs">
          <button type="button" class="chip is-selected" aria-pressed="true">Calculator</button>
          <button type="button" class="chip" disabled title="Practice mode is coming next">Practice</button>
        </div>
        <span>Practice mode with graded problems is next — the calculator comes first so the math is out in the open.</span>
      </aside>
    </header>

    <section class="calc-panel" aria-label="Flight computer calculator">
      <div class="calc-tabs" aria-label="Choose a calculation">
        <span>Calculation</span>
        <button type="button" class="chip is-selected" data-panel="wind" aria-pressed="true">Wind triangle</button>
        <button type="button" class="chip" data-panel="tsd" aria-pressed="false">Time · speed · distance</button>
        <button type="button" class="chip" data-panel="fuel" aria-pressed="false">Fuel</button>
        <button type="button" class="chip" data-panel="altitude" aria-pressed="false">Altitudes</button>
        <button type="button" class="chip" data-panel="tas" aria-pressed="false">True airspeed</button>
        <button type="button" class="chip" data-panel="convert" aria-pressed="false">Conversions</button>
      </div>

      <!-- Wind triangle -->
      <div class="calc-view" data-panel-view="wind">
        <form class="calc-form" data-calc="wind" novalidate>
          <h2>Wind triangle</h2>
          <p class="calc-help">Given your true course, true airspeed, and the winds aloft, find the wind correction angle, true heading, and ground speed.</p>
          <div class="field-row">
            <label>
              <span>True course (°)</span>
              <input name="tc" type="number" min="0" max="360" step="any" inputmode="numeric" autocomplete="off" placeholder="090" />
            </label>
            <label>
              <span>True airspeed (kts)</span>
              <input name="tas" type="number" min="1" step="any" inputmode="numeric" autocomplete="off" placeholder="110" />
            </label>
            <label>
              <span>Wind from (°)</span>
              <input name="wdir" type="number" min="0" max="360" step="any" inputmode="numeric" autocomplete="off" placeholder="040" />
            </label>
            <label>
              <span>Wind speed (kts)</span>
              <input name="wspd" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="15" />
            </label>
          </div>
          <div class="actions">
            <button type="submit" class="primary-action">Calculate</button>
          </div>
          <div class="result-zone" data-result aria-live="polite"></div>
        </form>
      </div>

      <!-- Time / speed / distance -->
      <div class="calc-view" data-panel-view="tsd" hidden>
        <form class="calc-form" data-calc="tsd" data-mode="time" novalidate>
          <h2>Time, speed, distance</h2>
          <p class="calc-help">Know two, solve the third — the bread and butter of every cross-country log.</p>
          <div class="mode-row" aria-label="Solve for">
            <span>Solve for</span>
            <button type="button" class="chip is-selected" data-mode-chip="time" aria-pressed="true">Time</button>
            <button type="button" class="chip" data-mode-chip="speed" aria-pressed="false">Ground speed</button>
            <button type="button" class="chip" data-mode-chip="distance" aria-pressed="false">Distance</button>
          </div>

          <fieldset class="field-row" data-mode-view="time">
            <legend class="sr-only">Solve for time</legend>
            <label>
              <span>Ground speed (kts)</span>
              <input name="time-gs" type="number" min="1" step="any" inputmode="numeric" autocomplete="off" placeholder="110" />
            </label>
            <label>
              <span>Distance (NM)</span>
              <input name="time-dist" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="165" />
            </label>
          </fieldset>

          <fieldset class="field-row" data-mode-view="speed" hidden>
            <legend class="sr-only">Solve for ground speed</legend>
            <label>
              <span>Distance (NM)</span>
              <input name="speed-dist" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="240" />
            </label>
            <label class="time-field">
              <span>Time</span>
              <span class="time-inputs">
                <input name="speed-th" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="2" aria-label="Hours" />
                <small>hr</small>
                <input name="speed-tm" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="00" aria-label="Minutes" />
                <small>min</small>
              </span>
            </label>
          </fieldset>

          <fieldset class="field-row" data-mode-view="distance" hidden>
            <legend class="sr-only">Solve for distance</legend>
            <label>
              <span>Ground speed (kts)</span>
              <input name="dist-gs" type="number" min="1" step="any" inputmode="numeric" autocomplete="off" placeholder="95" />
            </label>
            <label class="time-field">
              <span>Time</span>
              <span class="time-inputs">
                <input name="dist-th" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="1" aria-label="Hours" />
                <small>hr</small>
                <input name="dist-tm" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="12" aria-label="Minutes" />
                <small>min</small>
              </span>
            </label>
          </fieldset>

          <div class="actions">
            <button type="submit" class="primary-action">Calculate</button>
          </div>
          <div class="result-zone" data-result aria-live="polite"></div>
        </form>
      </div>

      <!-- Fuel -->
      <div class="calc-view" data-panel-view="fuel" hidden>
        <form class="calc-form" data-calc="fuel" data-mode="burned" novalidate>
          <h2>Fuel</h2>
          <p class="calc-help">Burn rate in gallons per hour, straight from your POH cruise tables.</p>
          <div class="mode-row" aria-label="Fuel calculation type">
            <span>Find</span>
            <button type="button" class="chip is-selected" data-mode-chip="burned" aria-pressed="true">Fuel burned</button>
            <button type="button" class="chip" data-mode-chip="endurance" aria-pressed="false">Endurance</button>
            <button type="button" class="chip" data-mode-chip="required" aria-pressed="false">Fuel required</button>
          </div>

          <fieldset class="field-row" data-mode-view="burned">
            <legend class="sr-only">Fuel burned</legend>
            <label>
              <span>Burn rate (GPH)</span>
              <input name="burned-gph" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="8.5" />
            </label>
            <label class="time-field">
              <span>Time</span>
              <span class="time-inputs">
                <input name="burned-th" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="2" aria-label="Hours" />
                <small>hr</small>
                <input name="burned-tm" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="30" aria-label="Minutes" />
                <small>min</small>
              </span>
            </label>
          </fieldset>

          <fieldset class="field-row" data-mode-view="endurance" hidden>
            <legend class="sr-only">Endurance</legend>
            <label>
              <span>Usable fuel (gal)</span>
              <input name="end-gal" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="38" />
            </label>
            <label>
              <span>Burn rate (GPH)</span>
              <input name="end-gph" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="9.5" />
            </label>
          </fieldset>

          <fieldset class="field-row" data-mode-view="required" hidden>
            <legend class="sr-only">Fuel required</legend>
            <label>
              <span>Burn rate (GPH)</span>
              <input name="req-gph" type="number" min="0" step="any" inputmode="decimal" autocomplete="off" placeholder="9" />
            </label>
            <label class="time-field">
              <span>Trip time</span>
              <span class="time-inputs">
                <input name="req-th" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="2" aria-label="Hours" />
                <small>hr</small>
                <input name="req-tm" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="00" aria-label="Minutes" />
                <small>min</small>
              </span>
            </label>
            <label>
              <span>Reserve (min) <small>optional</small></span>
              <input name="req-reserve" type="number" min="0" step="any" inputmode="numeric" autocomplete="off" placeholder="45" />
            </label>
          </fieldset>

          <div class="actions">
            <button type="submit" class="primary-action">Calculate</button>
          </div>
          <div class="result-zone" data-result aria-live="polite"></div>
        </form>
      </div>

      <!-- Altitudes -->
      <div class="calc-view" data-panel-view="altitude" hidden>
        <div class="altitude-grid">
          <form class="calc-form" data-calc="pa" novalidate>
            <h2>Pressure altitude</h2>
            <p class="calc-help">What the altimeter would read set to 29.92 — the entry point for performance charts.</p>
            <div class="field-row">
              <label>
                <span>Field elevation (ft)</span>
                <input name="pa-elev" type="number" step="any" inputmode="numeric" autocomplete="off" placeholder="1200" />
              </label>
              <label>
                <span>Altimeter setting (inHg)</span>
                <input name="pa-alt" type="number" min="28" max="31.5" step="any" inputmode="decimal" autocomplete="off" placeholder="29.92" />
              </label>
            </div>
            <div class="actions">
              <button type="submit" class="primary-action">Calculate</button>
            </div>
            <div class="result-zone" data-result aria-live="polite"></div>
          </form>

          <form class="calc-form" data-calc="da" novalidate>
            <h2>Density altitude</h2>
            <p class="calc-help">The altitude your airplane thinks it's at. Start from the pressure altitude you just found.</p>
            <div class="field-row">
              <label>
                <span>Pressure altitude (ft)</span>
                <input name="da-pa" type="number" step="any" inputmode="numeric" autocomplete="off" placeholder="5000" />
              </label>
              <label>
                <span>Outside air temp (°C)</span>
                <input name="da-oat" type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="25" />
              </label>
            </div>
            <div class="actions">
              <button type="submit" class="primary-action">Calculate</button>
            </div>
            <div class="result-zone" data-result aria-live="polite"></div>
          </form>
        </div>
      </div>

      <!-- True airspeed -->
      <div class="calc-view" data-panel-view="tas" hidden>
        <form class="calc-form" data-calc="tas" novalidate>
          <h2>True airspeed</h2>
          <p class="calc-help">Quick rule-of-thumb TAS from calibrated airspeed: about 2% faster per 1,000 ft of density altitude.</p>
          <div class="field-row">
            <label>
              <span>Calibrated airspeed (kts)</span>
              <input name="tas-cas" type="number" min="1" step="any" inputmode="numeric" autocomplete="off" placeholder="110" />
            </label>
            <label>
              <span>Pressure altitude (ft)</span>
              <input name="tas-pa" type="number" step="any" inputmode="numeric" autocomplete="off" placeholder="6500" />
            </label>
            <label>
              <span>Outside air temp (°C)</span>
              <input name="tas-oat" type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="15" />
            </label>
          </div>
          <div class="actions">
            <button type="submit" class="primary-action">Calculate</button>
          </div>
          <div class="result-zone" data-result aria-live="polite"></div>
        </form>
      </div>

      <!-- Conversions -->
      <div class="calc-view" data-panel-view="convert" hidden>
        <div class="calc-form">
          <h2>Conversions</h2>
          <p class="calc-help">Type in either box — the other converts as you go.</p>
          <div class="mode-row" aria-label="Conversion type" data-convert-tabs>
            <span>Convert</span>
            <button type="button" class="chip is-selected" data-pair-chip="kt-mph" aria-pressed="true">kts ↔ mph</button>
            <button type="button" class="chip" data-pair-chip="nm-sm" aria-pressed="false">NM ↔ SM</button>
            <button type="button" class="chip" data-pair-chip="nm-km" aria-pressed="false">NM ↔ km</button>
            <button type="button" class="chip" data-pair-chip="gal-lbs" aria-pressed="false">gal ↔ lbs</button>
            <button type="button" class="chip" data-pair-chip="c-f" aria-pressed="false">°C ↔ °F</button>
          </div>

          <div class="convert-pair" data-pair-view="kt-mph">
            <label><span>Knots</span><input data-convert-a type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="100" /></label>
            <span class="convert-eq" aria-hidden="true">=</span>
            <label><span>Miles per hour</span><input data-convert-b type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="115.1" /></label>
            <p class="convert-note" data-convert-note>1 kt = 1.15078 mph</p>
          </div>
          <div class="convert-pair" data-pair-view="nm-sm" hidden>
            <label><span>Nautical miles</span><input data-convert-a type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="100" /></label>
            <span class="convert-eq" aria-hidden="true">=</span>
            <label><span>Statute miles</span><input data-convert-b type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="115.1" /></label>
            <p class="convert-note" data-convert-note>1 NM = 1.15078 SM</p>
          </div>
          <div class="convert-pair" data-pair-view="nm-km" hidden>
            <label><span>Nautical miles</span><input data-convert-a type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="100" /></label>
            <span class="convert-eq" aria-hidden="true">=</span>
            <label><span>Kilometers</span><input data-convert-b type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="185.2" /></label>
            <p class="convert-note" data-convert-note>1 NM = 1.852 km (exact)</p>
          </div>
          <div class="convert-pair" data-pair-view="gal-lbs" hidden>
            <label><span>Gallons (avgas)</span><input data-convert-a type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="30" /></label>
            <span class="convert-eq" aria-hidden="true">=</span>
            <label><span>Pounds</span><input data-convert-b type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="180" /></label>
            <p class="convert-note" data-convert-note>Avgas flight-planning weight: 6 lbs per gallon</p>
          </div>
          <div class="convert-pair" data-pair-view="c-f" hidden>
            <label><span>Celsius</span><input data-convert-a type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="15" /></label>
            <span class="convert-eq" aria-hidden="true">=</span>
            <label><span>Fahrenheit</span><input data-convert-b type="number" step="any" inputmode="decimal" autocomplete="off" placeholder="59" /></label>
            <p class="convert-note" data-convert-note>°F = °C × 1.8 + 32</p>
          </div>
        </div>
      </div>
    </section>

    <aside class="practice-note" role="note">
      <div class="note-marker" aria-hidden="true">!</div>
      <div>
        <h2>Training note</h2>
        <p>
          Your manual flight computer — whichever brand you fly with — stays the source of truth for checkride prep. This
          trainer is for building speed and intuition between lessons, and for checking your work when you practice at home.
        </p>
      </div>
    </aside>

    <!-- TODO: wire Kit form — UID + tag pending, see site-map-and-funnels.md. Do not link a download asset until the funnel is live. -->
    <form class="capture-card" data-action="pdf-stub" aria-labelledby="fc-capture-title">
      <p class="capture-title" id="fc-capture-title">Get a printable practice problem set</p>
      <p class="capture-body">
        A worked set of E6B practice problems — wind triangles, fuel, and density altitude with full solutions — as a
        printable PDF for the flight bag.
      </p>
      <label class="capture-label">
        <span>Email</span>
        <input class="capture-input" type="email" placeholder="you@email.com" autocomplete="email" disabled />
      </label>
      <button class="primary-action" type="submit" disabled>Coming soon</button>
      <p class="capture-hint">Email delivery is not wired yet.</p>
    </form>

    <p class="fc-disclaimer">
      Flight School Friend is an independent educational resource. It is not legal, medical, financial, or FAA certification
      advice. Always verify requirements with the FAA, your aviation medical examiner, and your flight school.
    </p>
    <p class="fc-disclaimer">Practice reference only — verify performance calculations with your POH and your instructor.</p>
  </div>
</section>

<script>
  // @ts-nocheck
  import {
    cToF,
    densityAltitude,
    distanceFromSpeedTime,
    fToC,
    fuelBurned,
    fuelEndurance,
    fuelRequired,
    galToLbs,
    kmToNm,
    ktsToMph,
    lbsToGal,
    mphToKts,
    nmToKm,
    nmToSm,
    pressureAltitude,
    smToNm,
    speedFromDistanceTime,
    timeFromSpeedDistance,
    trueAirspeed,
    windTriangle,
  } from '@/lib/flight-computer/engines';

  const root = document.querySelector('.fsf-flightcomp');
  if (root) init(root);

  function init(root) {
    const escapeHtml = (value) =>
      String(value).replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
      })[char]);

    const round = (value, places = 0) => {
      const factor = 10 ** places;
      const r = Math.round(value * factor) / factor;
      return Object.is(r, -0) ? 0 : r;
    };
    const fmtNum = (value, places = 0) => round(value, places).toLocaleString('en-US');
    const pad3 = (deg) => String(Math.round(deg)).padStart(3, '0');
    const fmtHours = (hours) => {
      const totalMin = Math.round(hours * 60);
      const hh = Math.floor(totalMin / 60);
      const mm = totalMin % 60;
      return `${round(hours, 2)} hr (${hh}:${String(mm).padStart(2, '0')})`;
    };

    /** Read a numeric field; blank or junk comes back NaN so engines can reject it. */
    const numField = (form, name) => {
      const field = form.elements[name];
      const raw = field ? String(field.value).trim() : '';
      return raw === '' ? NaN : Number(raw);
    };

    /** Combine an hours + minutes field pair into decimal hours. NaN if both blank. */
    const hoursField = (form, prefix) => {
      const hField = form.elements[`${prefix}h`];
      const mField = form.elements[`${prefix}m`];
      const hRaw = hField ? String(hField.value).trim() : '';
      const mRaw = mField ? String(mField.value).trim() : '';
      if (hRaw === '' && mRaw === '') return NaN;
      const h = hRaw === '' ? 0 : Number(hRaw);
      const m = mRaw === '' ? 0 : Number(mRaw);
      if (!Number.isFinite(h) || !Number.isFinite(m) || h < 0 || m < 0) return NaN;
      return h + m / 60;
    };

    const renderResult = (zone, headline, rows, steps, methodNote) => {
      zone.innerHTML = `
        <div class="result-strip">${escapeHtml(headline)}</div>
        ${rows && rows.length ? `
          <dl class="result-rows">
            ${rows.map(([term, detail]) => `<div><dt>${escapeHtml(term)}</dt><dd>${escapeHtml(detail)}</dd></div>`).join('')}
          </dl>` : ''}
        <details class="how">
          <summary>How this is computed</summary>
          <ol>${steps.map((step) => `<li>${escapeHtml(step)}</li>`).join('')}</ol>
          ${methodNote ? `<p class="method-note">${escapeHtml(methodNote)}</p>` : ''}
        </details>
      `;
    };

    const renderError = (zone, message) => {
      zone.innerHTML = `<div class="result-error">${escapeHtml(message)}</div>`;
    };

    // ---- Panel switching -------------------------------------------------
    const panelChips = Array.from(root.querySelectorAll('[data-panel]'));
    const panelViews = Array.from(root.querySelectorAll('[data-panel-view]'));

    panelChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        panelChips.forEach((other) => {
          const selected = other === chip;
          other.classList.toggle('is-selected', selected);
          other.setAttribute('aria-pressed', String(selected));
        });
        panelViews.forEach((view) => {
          view.hidden = view.dataset.panelView !== chip.dataset.panel;
        });
      });
    });

    // ---- Sub-mode switching (TSD solve-for, fuel find) -------------------
    root.querySelectorAll('form[data-mode]').forEach((form) => {
      const modeChips = Array.from(form.querySelectorAll('[data-mode-chip]'));
      const modeViews = Array.from(form.querySelectorAll('[data-mode-view]'));
      modeChips.forEach((chip) => {
        chip.addEventListener('click', () => {
          form.dataset.mode = chip.dataset.modeChip;
          modeChips.forEach((other) => {
            const selected = other === chip;
            other.classList.toggle('is-selected', selected);
            other.setAttribute('aria-pressed', String(selected));
          });
          modeViews.forEach((view) => {
            view.hidden = view.dataset.modeView !== chip.dataset.modeChip;
          });
          const zone = form.querySelector('[data-result]');
          if (zone) zone.innerHTML = '';
        });
      });
    });

    // ---- Calculators -----------------------------------------------------
    const calculators = {
      wind(form, zone) {
        const result = windTriangle({
          trueCourse: numField(form, 'tc'),
          trueAirspeed: numField(form, 'tas'),
          windDirection: numField(form, 'wdir'),
          windSpeed: numField(form, 'wspd'),
        });
        if (!result.ok) return renderError(zone, result.error);
        const wca = round(result.windCorrectionAngle);
        const wcaLabel = wca === 0 ? '0° — no crab needed' : `${Math.abs(wca)}° ${wca > 0 ? 'right' : 'left'} (crab into the wind)`;
        const hw = round(result.headwindComponent);
        const xw = round(result.crosswindComponent);
        const hwLabel = hw >= 0 ? `${hw} kt headwind` : `${Math.abs(hw)} kt tailwind`;
        const xwLabel = xw === 0 ? 'no crosswind' : `${Math.abs(xw)} kt crosswind from the ${xw > 0 ? 'right' : 'left'}`;
        renderResult(
          zone,
          `Heading ${pad3(result.trueHeading)}° · Ground speed ${fmtNum(result.groundSpeed)} kts`,
          [
            ['Wind correction angle', wcaLabel],
            ['Wind components', `${hwLabel} · ${xwLabel}`],
          ],
          result.steps,
          'This is the same triangle the wind side of a manual flight computer solves graphically — your wind vector set against your true course.'
        );
      },

      tsd(form, zone) {
        const mode = form.dataset.mode;
        if (mode === 'time') {
          const result = timeFromSpeedDistance(numField(form, 'time-gs'), numField(form, 'time-dist'));
          if (!result.ok) return renderError(zone, result.error);
          return renderResult(zone, `Time ${fmtHours(result.value)}`, [], result.steps);
        }
        if (mode === 'speed') {
          const result = speedFromDistanceTime(numField(form, 'speed-dist'), hoursField(form, 'speed-t'));
          if (!result.ok) return renderError(zone, result.error);
          return renderResult(zone, `Ground speed ${fmtNum(result.value)} kts`, [], result.steps);
        }
        const result = distanceFromSpeedTime(numField(form, 'dist-gs'), hoursField(form, 'dist-t'));
        if (!result.ok) return renderError(zone, result.error);
        return renderResult(zone, `Distance ${fmtNum(result.value, 1)} NM`, [], result.steps);
      },

      fuel(form, zone) {
        const mode = form.dataset.mode;
        if (mode === 'burned') {
          const result = fuelBurned(numField(form, 'burned-gph'), hoursField(form, 'burned-t'));
          if (!result.ok) return renderError(zone, result.error);
          return renderResult(zone, `Fuel burned ${fmtNum(result.value, 1)} gal`, [], result.steps);
        }
        if (mode === 'endurance') {
          const result = fuelEndurance(numField(form, 'end-gal'), numField(form, 'end-gph'));
          if (!result.ok) return renderError(zone, result.error);
          return renderResult(
            zone,
            `Endurance ${fmtHours(result.value)}`,
            [],
            result.steps,
            'Plan to be on the ground well before this — your legal reserve is a minimum, not a target.'
          );
        }
        const reserveRaw = String(form.elements['req-reserve'].value).trim();
        const reserveHours = reserveRaw === '' ? 0 : Number(reserveRaw) / 60;
        const result = fuelRequired(numField(form, 'req-gph'), hoursField(form, 'req-t'), reserveHours);
        if (!result.ok) return renderError(zone, result.error);
        return renderResult(zone, `Fuel required ${fmtNum(result.value, 1)} gal`, [], result.steps);
      },

      pa(form, zone) {
        const result = pressureAltitude(numField(form, 'pa-elev'), numField(form, 'pa-alt'));
        if (!result.ok) return renderError(zone, result.error);
        renderResult(
          zone,
          `Pressure altitude ${fmtNum(result.value)} ft`,
          [],
          result.steps,
          'Rule of thumb: about 1,000 ft per inch of pressure. Lower setting than 29.92 means higher pressure altitude.'
        );
      },

      da(form, zone) {
        const result = densityAltitude(numField(form, 'da-pa'), numField(form, 'da-oat'));
        if (!result.ok) return renderError(zone, result.error);
        renderResult(
          zone,
          `Density altitude ${fmtNum(result.value)} ft`,
          [],
          result.steps,
          'Rule of thumb: about 120 ft per °C of ISA deviation. Performance charts curve a little; this is the planning approximation.'
        );
      },

      tas(form, zone) {
        const result = trueAirspeed(numField(form, 'tas-cas'), numField(form, 'tas-pa'), numField(form, 'tas-oat'));
        if (!result.ok) return renderError(zone, result.error);
        renderResult(
          zone,
          `True airspeed ${fmtNum(result.value)} kts`,
          [['Density altitude used', `${fmtNum(result.densityAltitudeFt)} ft`]],
          result.steps,
          'Rule of thumb: add 2% of CAS per 1,000 ft of density altitude. The precise wheel on your flight computer will read slightly differently — that is expected.'
        );
      },
    };

    root.querySelectorAll('form[data-calc]').forEach((form) => {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const zone = form.querySelector('[data-result]');
        const calculate = calculators[form.dataset.calc];
        if (zone && calculate) calculate(form, zone);
      });
    });

    // ---- Conversions (live, bidirectional) --------------------------------
    const converters = {
      'kt-mph': { aToB: ktsToMph, bToA: mphToKts, idle: '1 kt = 1.15078 mph' },
      'nm-sm': { aToB: nmToSm, bToA: smToNm, idle: '1 NM = 1.15078 SM' },
      'nm-km': { aToB: nmToKm, bToA: kmToNm, idle: '1 NM = 1.852 km (exact)' },
      'gal-lbs': { aToB: galToLbs, bToA: lbsToGal, idle: 'Avgas flight-planning weight: 6 lbs per gallon' },
      'c-f': { aToB: cToF, bToA: fToC, idle: '°F = °C × 1.8 + 32' },
    };

    const pairChips = Array.from(root.querySelectorAll('[data-pair-chip]'));
    const pairViews = Array.from(root.querySelectorAll('[data-pair-view]'));

    pairChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        pairChips.forEach((other) => {
          const selected = other === chip;
          other.classList.toggle('is-selected', selected);
          other.setAttribute('aria-pressed', String(selected));
        });
        pairViews.forEach((view) => {
          view.hidden = view.dataset.pairView !== chip.dataset.pairChip;
        });
      });
    });

    pairViews.forEach((view) => {
      const converter = converters[view.dataset.pairView];
      const inputA = view.querySelector('[data-convert-a]');
      const inputB = view.querySelector('[data-convert-b]');
      const note = view.querySelector('[data-convert-note]');

      const update = (source, target, fn) => {
        const raw = String(source.value).trim();
        if (raw === '') {
          target.value = '';
          note.textContent = converter.idle;
          return;
        }
        const result = fn(Number(raw));
        if (!result.ok) {
          note.textContent = result.error;
          return;
        }
        target.value = String(round(result.value, 2));
        note.textContent = result.steps[0];
      };

      inputA.addEventListener('input', () => update(inputA, inputB, converter.aToB));
      inputB.addEventListener('input', () => update(inputB, inputA, converter.bToA));
    });

    // ---- Capture stub ------------------------------------------------------
    root.querySelector('[data-action="pdf-stub"]')?.addEventListener('submit', (event) => {
      event.preventDefault();
      // TODO: wire Kit form — UID + tag pending, see site-map-and-funnels.md
    });
  }
</script>

