    --border-strong: #CBD5E1;
    --text-strong: #0E1B2E;
    --text-body: #334155;
    --text-muted: #64748B;
    --primary: #0B69D6;
    --primary-hover: #0A5BBA;
    --primary-soft: #EAF3FE;
    --success: #1F9D5B;
    --warning: #E08600;
    --error: #DC2B36;
    --shadow-sm: 0 1px 3px rgba(14, 27, 46, 0.06), 0 1px 2px rgba(14, 27, 46, 0.04);
    --shadow-md: 0 4px 12px rgba(14, 27, 46, 0.07), 0 2px 4px rgba(14, 27, 46, 0.04);
    background: var(--bg);
    color: var(--text-body);
  }

  .fc-shell {
    width: min(100% - clamp(2.5rem, 10vw, 6rem), 1080px);
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .fc-hero,
  .calc-panel,
  .practice-note,
  .capture-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--surface);
    box-shadow: var(--shadow-md);
  }

  .fc-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 280px);
    gap: 1.5rem;
    align-items: stretch;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .hero-copy h1,
  .calc-form h2,
  .practice-note h2 {
    margin: 0;
    color: var(--text-strong);
    letter-spacing: -0.015em;
  }

  .hero-copy h1 {
    max-width: 780px;
    font-size: clamp(2rem, 4vw, 2.5rem);
    line-height: 1.15;
  }

  .lead {
    max-width: 720px;
    margin: 1rem 0 0;
    font-size: 1.1875rem;
    line-height: 1.7;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--primary);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.75rem;
