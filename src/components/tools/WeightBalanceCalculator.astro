---
/**
 * Aircraft-agnostic weight & balance calculator.
 * All aircraft numbers come from the profile in `src/data/aircraft/` —
 * a future 172S version is a new constants file + a new route.
 */
import { AIRCRAFT_PROFILES } from '@/data/aircraft';

interface Props {
  aircraftId: string;
}

const { aircraftId } = Astro.props;
const profile = AIRCRAFT_PROFILES[aircraftId];
if (!profile) {
  throw new Error(`Unknown aircraft profile: ${aircraftId}`);
}

const SITE_DISCLAIMER =
  'Flight School Friend is an independent educational resource. It is not legal, medical, financial, or FAA certification advice. Always verify requirements with the FAA, your aviation medical examiner, and your flight school.';

const defaultTank =
  profile.fuel.tankOptions.find((t) => t.id === profile.fuel.defaultTankId) ??
  profile.fuel.tankOptions[0];
---

<section class="fsf-wb" aria-labelledby="wb-heading" data-aircraft-id={profile.id}>
  <div class="wb-shell">
    <header class="wb-hero">
      <div class="hero-copy">
        <p class="eyebrow">W&amp;B practice</p>
        <h1 id="wb-heading">Cessna 150 weight and balance calculator</h1>
        <p class="lead">
          Load up a {profile.name}, then watch where zero-fuel, takeoff, and landing land on the CG
          envelope. Built to practice the moment math you'll do for every flight.
        </p>
        <p class="source-note">
          Numbers from the <strong>{profile.source}</strong>. {profile.modelYearNote}
          {profile.datumNote}
        </p>
        <p class="source-note">
          {profile.categoryNote} Both categories are shown on the chart — they're one envelope on
          this type, so there's nothing to toggle.
        </p>
      </div>

      <aside class="useful-load-card" aria-label="Useful load">
        <p class="eyebrow">Useful load</p>
        <strong><span data-useful-load>—</span> lb</strong>
        <span class="useful-load-formula">max gross − empty weight − oil</span>
        <span class="useful-load-note">
          The 150's real constraint: people + bags + fuel all have to fit inside this number.
        </span>
      </aside>
    </header>

    <aside class="practice-callout" role="note">
      <div class="note-marker" aria-hidden="true">!</div>
      <div>
        <h2>Practice aid only</h2>
        <p>
          This page is for learning the method. The POH/AFM and your aircraft's current
          weight-and-balance record are the only valid source for real flight planning. Never fly
          on numbers from this page.
        </p>
      </div>
    </aside>

    <div class="input-grid no-print">
      <section class="panel" aria-labelledby="wb-aircraft-heading">
        <h2 id="wb-aircraft-heading">Your aircraft</h2>
        <p class="panel-hint">
          Pre-filled from the 150 I fly — replace with <strong>your</strong> aircraft's current
          weighing record. Every airplane differs.
        </p>

        <div class="field">
          <label for="wb-empty-weight">Basic empty weight (lb)</label>
          <input
            id="wb-empty-weight"
            data-empty-weight
            type="number"
            inputmode="decimal"
            min="0"
            step="1"
            value={profile.defaultEmpty.weightLb}
          />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="wb-empty-cg">Empty CG (in aft of datum)</label>
            <input
              id="wb-empty-cg"
              data-empty-cg
              type="number"
              inputmode="decimal"
              step="0.01"
              value={profile.defaultEmpty.cgIn}
            />
          </div>
          <div class="field">
            <label for="wb-empty-moment">Empty moment (in·lb)</label>
            <input
              id="wb-empty-moment"
              data-empty-moment
              type="number"
              inputmode="decimal"
              step="1"
              value={profile.defaultEmpty.momentInLb}
            />
          </div>
        </div>
        <p class="field-note">CG and moment stay in sync — edit whichever your record lists.</p>

        <div class="field">
          <label for="wb-oil">Oil in the sump (qt)</label>
          <input
            id="wb-oil"
            data-oil
            type="number"
            inputmode="decimal"
            min="0"
            max={profile.oil.capacityQt}
            step="0.5"
            value={profile.oil.defaultQt}
          />
          <p class="field-note">
            {profile.oil.capacityQt} qt sump at {profile.oil.armIn} in ({profile.oil.lbsPerQt} lb/qt).
            Default {profile.oil.defaultQt} qt is the manual's normal-flight fill; {profile.oil.minOperatingQt} qt
            is the minimum for normal operation.
          </p>
          <p class="field-note field-note-strong">
            Older Cessna empty weights often <strong>exclude</strong> oil — check your weighing
            record. If yours includes oil, set this to 0.
          </p>
        </div>
      </section>

      <section class="panel" aria-labelledby="wb-load-heading">
        <h2 id="wb-load-heading">Load the airplane</h2>

        {profile.loadStations.map((s) => (
          <div class="field">
            <label for={`wb-station-${s.id}`}>
              {s.label} (lb) <span class="arm-tag">arm +{s.armIn} in</span>
            </label>
            <input
              id={`wb-station-${s.id}`}
              data-station={s.id}
              type="number"
              inputmode="decimal"
              min="0"
              step="1"
              value={s.id === 'frontSeats' ? 170 : 0}
            />
            {s.help && <p class="field-note">{s.help}</p>}
          </div>
        ))}

        <div class="field">
          <span class="chip-label" id="wb-tank-label">Fuel tanks</span>
          <div class="chip-row" role="group" aria-labelledby="wb-tank-label">
            {profile.fuel.tankOptions.map((t) => (
              <button
                type="button"
                class={`chip${t.id === defaultTank.id ? ' is-selected' : ''}`}
                data-tank={t.id}
                aria-pressed={t.id === defaultTank.id ? 'true' : 'false'}
              >
                {t.label}
                <span class="chip-sub">{t.totalGal} total / {t.usableGal} usable gal</span>
              </button>
            ))}
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="wb-fuel">Fuel on board (usable gal)</label>
            <input
              id="wb-fuel"
              data-fuel
              type="number"
              inputmode="decimal"
              min="0"
              max={defaultTank.usableGal}
              step="0.5"
              value={defaultTank.usableGal}
            />
            <p class="field-note" data-fuel-hint>
              At {profile.fuel.lbsPerGal} lb/gal, arm +{profile.fuel.armIn} in. Capped at the
              selected tanks' usable fuel.
            </p>
          </div>
          <div class="field">
            <label for="wb-burn">Fuel burn this flight (gal)</label>
            <input
              id="wb-burn"
              data-burn
              type="number"
              inputmode="decimal"
              min="0"
              step="0.5"
              value="6"
            />
            <p class="field-note">Landing = takeoff minus this burn.</p>
          </div>
        </div>
      </section>
    </div>

    <section class="panel results-panel" aria-labelledby="wb-results-heading">
      <div class="results-head">
        <h2 id="wb-results-heading">Results</h2>
        <button type="button" class="ghost-action no-print" data-print>Print this summary</button>
      </div>
      <p class="results-tank">Tank option: <strong data-tank-readout>{defaultTank.label}</strong></p>

      <div class="warnings" data-warnings aria-live="polite"></div>

      <div class="table-scroll">
        <table class="conditions-table">
          <caption class="sr-only">Weight, CG, and moment for zero fuel, takeoff, and landing</caption>
          <thead>
            <tr>
              <th scope="col">Condition</th>
              <th scope="col">Weight (lb)</th>
              <th scope="col">CG (in aft of datum)</th>
              <th scope="col">Moment (in·lb)</th>
              <th scope="col">Envelope check</th>
            </tr>
          </thead>
          <tbody data-conditions-body></tbody>
        </table>
      </div>

      <figure class="chart-card">
        <svg
          data-envelope-chart
          viewBox="0 0 640 460"
          role="img"
          aria-label="CG envelope chart"
          preserveAspectRatio="xMidYMid meet"
        ></svg>
        <figcaption class="chart-legend" data-chart-legend>
          <span class="legend-item"><span class="swatch swatch-zf" aria-hidden="true"></span> Zero fuel (circle)</span>
          <span class="legend-item"><span class="swatch swatch-to" aria-hidden="true"></span> Takeoff (diamond)</span>
          <span class="legend-item"><span class="swatch swatch-ld" aria-hidden="true"></span> Landing (square)</span>
          <span class="legend-item"><span class="swatch swatch-travel" aria-hidden="true"></span> CG travel, takeoff → landing</span>
        </figcaption>
      </figure>

      <h3>Stations and moments</h3>
      <div class="table-scroll">
        <table class="stations-table">
          <caption class="sr-only">Per-station weights, arms, and moments</caption>
          <thead>
            <tr>
              <th scope="col">Station</th>
              <th scope="col">Weight (lb)</th>
              <th scope="col">Arm (in)</th>
              <th scope="col">Moment (in·lb)</th>
            </tr>
          </thead>
          <tbody data-stations-body></tbody>
        </table>
      </div>
    </section>

    <details class="find-numbers no-print">
      <summary>Where to find these numbers for your airplane</summary>
      <div class="find-numbers-body">
        <ul>
          <li>
            <strong>Basic empty weight, CG, and moment</strong> come from the aircraft's current
            <em>weight and balance record</em> — a sheet in the aircraft documents, updated every
            time equipment changes (look for the most recent entry, often attached to an FAA Form
            337 or an equipment-change worksheet).
          </li>
          <li>
            <strong>Arms and limits</strong> come from the POH/AFM or owner's manual for your exact
            model year — they differ between 150 variants.
          </li>
          <li>
            <strong>Whether oil is included</strong> is stated on the weighing record. Older
            records often list empty weight without oil; newer ones usually include it.
          </li>
          <li>
            Renting? Ask the school for the current W&amp;B sheet for the specific tail number you
            fly — not a fleet average.
          </li>
        </ul>
        <!-- TODO (post math sign-off): labeled generic weighing-record illustration — flat vector, DS tokens, not a real document. -->
      </div>
    </details>

    <!-- TODO: email capture — intentionally unwired in v1. Do not connect a provider yet. -->
    <aside class="capture-placeholder no-print" aria-label="Email updates placeholder">
      <p class="eyebrow">Coming soon</p>
      <p>
        A printable W&amp;B worksheet by email is planned — capture isn't wired up yet, so there's
        nothing to submit here.
      </p>
    </aside>

    <aside class="practice-note" role="note">
      <div class="note-marker" aria-hidden="true">!</div>
      <div>
        <h2>Before any real flight</h2>
        <p>
          Never fly on numbers from this page — compute W&amp;B from your aircraft's POH and
          current weight-and-balance record.
        </p>
        <p class="disclaimer">{SITE_DISCLAIMER}</p>
      </div>
    </aside>
  </div>
</section>

<script>
  // @ts-nocheck
  import { AIRCRAFT_PROFILES } from '@/data/aircraft';
  import { computeWB, forwardLimitAt, fmtLb, fmtIn, fmtGal } from '@/lib/weight-balance';

  const root = document.querySelector('.fsf-wb');
  const profile = AIRCRAFT_PROFILES[root?.dataset.aircraftId ?? ''];
  if (root && profile) {
    const $ = (sel) => root.querySelector(sel);
    const emptyWeightInput = $('[data-empty-weight]');
    const emptyCgInput = $('[data-empty-cg]');
    const emptyMomentInput = $('[data-empty-moment]');
    const oilInput = $('[data-oil]');
    const fuelInput = $('[data-fuel]');
    const burnInput = $('[data-burn]');
    const stationInputs = Array.from(root.querySelectorAll('[data-station]'));
    const tankButtons = Array.from(root.querySelectorAll('[data-tank]'));
    const tankReadout = $('[data-tank-readout]');
    const usefulLoad = $('[data-useful-load]');
    const warnings = $('[data-warnings]');
    const conditionsBody = $('[data-conditions-body]');
    const stationsBody = $('[data-stations-body]');
    const chart = $('[data-envelope-chart]');
    const printBtn = $('[data-print]');

    const state = {
      tankId: profile.fuel.defaultTankId,
    };

    const num = (input) => {
      const v = Number.parseFloat(input?.value ?? '');
      return Number.isFinite(v) ? v : 0;
    };

    function currentTank() {
      return (
        profile.fuel.tankOptions.find((t) => t.id === state.tankId) ?? profile.fuel.tankOptions[0]
      );
    }

    function readInputs() {
      const stationWeightsLb = {};
      for (const input of stationInputs) stationWeightsLb[input.dataset.station] = num(input);
      return {
        emptyWeightLb: num(emptyWeightInput),
        emptyMomentInLb: num(emptyMomentInput),
        oilQt: num(oilInput),
        stationWeightsLb,
        tankId: state.tankId,
        fuelGal: num(fuelInput),
        fuelBurnGal: num(burnInput),
      };
    }

    // --- Empty weight / CG / moment two-way sync (moment is source of truth) ---
    function syncMomentFromCg() {
      const m = num(emptyWeightInput) * num(emptyCgInput);
      emptyMomentInput.value = String(Math.round(m));
    }
    function syncCgFromMoment() {
      const w = num(emptyWeightInput);
      if (w > 0) emptyCgInput.value = (num(emptyMomentInput) / w).toFixed(2);
    }
    emptyCgInput.addEventListener('input', () => {
      syncMomentFromCg();
      render();
    });
    emptyMomentInput.addEventListener('input', () => {
      syncCgFromMoment();
      render();
    });
    emptyWeightInput.addEventListener('input', () => {
      syncMomentFromCg();
      render();
    });

    // --- SVG chart ---
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const VIEW = { w: 640, h: 460, ml: 64, mr: 16, mt: 18, mb: 48 };
    const X_MIN = 30.5;
    const X_MAX = 38.5;
    const Y_MIN = 1050;
    const Y_MAX = 1700;
    const sx = (cg) =>
      VIEW.ml + ((cg - X_MIN) / (X_MAX - X_MIN)) * (VIEW.w - VIEW.ml - VIEW.mr);
    const sy = (w) =>
      VIEW.mt + ((Y_MAX - w) / (Y_MAX - Y_MIN)) * (VIEW.h - VIEW.mt - VIEW.mb);
    const clamp = (v, lo, hi) => Math.min(hi, Math.max(lo, v));

    function el(name, attrs, text) {
      const node = document.createElementNS(SVG_NS, name);
      for (const [k, v] of Object.entries(attrs)) node.setAttribute(k, String(v));
      if (text !== undefined) node.textContent = text;
      return node;
    }

    function drawChartBase() {
      chart.replaceChildren();
      // Grid + ticks
      for (let cg = Math.ceil(X_MIN); cg <= X_MAX; cg += 1) {
        chart.append(
          el('line', {
            x1: sx(cg), y1: sy(Y_MIN), x2: sx(cg), y2: sy(Y_MAX),
            class: 'grid-line',
          }),
          el('text', { x: sx(cg), y: VIEW.h - VIEW.mb + 20, class: 'tick-label', 'text-anchor': 'middle' }, String(cg)),
        );
      }
      for (let w = 1100; w <= Y_MAX; w += 100) {
        chart.append(
          el('line', {
            x1: sx(X_MIN), y1: sy(w), x2: sx(X_MAX), y2: sy(w),
            class: 'grid-line',
          }),
          el('text', { x: VIEW.ml - 8, y: sy(w) + 4, class: 'tick-label', 'text-anchor': 'end' }, w.toLocaleString('en-US')),
        );
      }
      // Axis titles
      chart.append(
        el('text', {
          x: VIEW.ml + (VIEW.w - VIEW.ml - VIEW.mr) / 2,
          y: VIEW.h - 6,
          class: 'axis-label',
          'text-anchor': 'middle',
        }, 'CG — inches aft of datum'),
        el('text', {
          x: 14,
          y: VIEW.mt + (VIEW.h - VIEW.mt - VIEW.mb) / 2,
          class: 'axis-label',
          'text-anchor': 'middle',
          transform: `rotate(-90 14 ${VIEW.mt + (VIEW.h - VIEW.mt - VIEW.mb) / 2})`,
        }, 'Weight — lb'),
      );
      // Envelope polygon: forward limit up, aft limit back down
      const boundary = [
        ...profile.envelope.forwardLimit,
        ...[...profile.envelope.aftLimit].reverse(),
      ];
      chart.append(
        el('polygon', {
          points: boundary.map((p) => `${sx(p.cgIn)},${sy(p.weightLb)}`).join(' '),
          class: 'envelope',
        }),
      );
      // Envelope caption inside the polygon
      chart.append(
        el('text', {
          x: sx(33.1), y: sy(1560), class: 'envelope-label', 'text-anchor': 'start',
        }, `Normal + Utility envelope — max ${profile.maxGrossLb.toLocaleString('en-US')} lb`),
      );
      // Dynamic overlay group
      chart.append(el('g', { 'data-overlay': '' }));
    }

    const POINT_STYLE = {
      zeroFuel: { cls: 'pt-zf', shape: 'circle' },
      takeoff: { cls: 'pt-to', shape: 'diamond' },
      landing: { cls: 'pt-ld', shape: 'square' },
    };

    function pointNode(cond) {
      const x = clamp(sx(cond.cgIn), VIEW.ml, VIEW.w - VIEW.mr);
      const y = clamp(sy(cond.weightLb), VIEW.mt, VIEW.h - VIEW.mb);
      const style = POINT_STYLE[cond.id];
      const bad = cond.issues.some((i) => i.kind === 'limit');
      const cls = `${style.cls}${bad ? ' pt-bad' : ''}`;
      const g = document.createElementNS(SVG_NS, 'g');
      if (style.shape === 'circle') {
        g.append(el('circle', { cx: x, cy: y, r: 6, class: `pt ${cls}` }));
      } else if (style.shape === 'diamond') {
        g.append(el('path', {
          d: `M ${x} ${y - 7} L ${x + 7} ${y} L ${x} ${y + 7} L ${x - 7} ${y} Z`,
          class: `pt ${cls}`,
        }));
      } else {
        g.append(el('rect', { x: x - 5.5, y: y - 5.5, width: 11, height: 11, class: `pt ${cls}` }));
      }
      const labelAnchor = x > VIEW.w - 130 ? 'end' : 'start';
      g.append(el('text', {
        x: labelAnchor === 'end' ? x - 10 : x + 10,
        y: cond.id === 'landing' ? y + 18 : y - 10,
        class: `pt-label ${bad ? 'pt-label-bad' : ''}`,
        'text-anchor': labelAnchor,
      }, `${cond.label} ${fmtLb(cond.weightLb)} lb / ${fmtIn(cond.cgIn)} in`));
      return g;
    }

    function drawPoints(result) {
      const overlay = chart.querySelector('[data-overlay]');
      overlay.replaceChildren();
      if (result.landing) {
        overlay.append(el('line', {
          x1: clamp(sx(result.takeoff.cgIn), VIEW.ml, VIEW.w - VIEW.mr),
          y1: clamp(sy(result.takeoff.weightLb), VIEW.mt, VIEW.h - VIEW.mb),
          x2: clamp(sx(result.landing.cgIn), VIEW.ml, VIEW.w - VIEW.mr),
          y2: clamp(sy(result.landing.weightLb), VIEW.mt, VIEW.h - VIEW.mb),
          class: 'travel-line',
        }));
      }
      overlay.append(pointNode(result.zeroFuel));
      if (result.landing) overlay.append(pointNode(result.landing));
      overlay.append(pointNode(result.takeoff));

      const parts = [result.zeroFuel, result.takeoff, ...(result.landing ? [result.landing] : [])]
        .map((c) => `${c.label}: ${fmtLb(c.weightLb)} pounds at ${fmtIn(c.cgIn)} inches`)
        .join('; ');
      chart.setAttribute(
        'aria-label',
        `CG envelope chart for the ${profile.name}. ${parts}${result.landing ? '' : '. Landing not computed'}`,
      );
    }

    // --- Icons (inline stroke SVG, Lucide-style) ---
    const ICONS = {
      limit:
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>',
      invalid:
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>',
      info:
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>',
      ok:
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>',
    };

    function renderWarnings(result) {
      warnings.replaceChildren();
      if (result.allIssues.length === 0) {
        const p = document.createElement('p');
        p.className = 'warning-row warning-ok';
        p.innerHTML = `${ICONS.ok}<span>No limits exceeded for the numbers entered.</span>`;
        warnings.append(p);
        return;
      }
      const list = document.createElement('ul');
      list.className = 'warning-list';
      for (const issue of result.allIssues) {
        const li = document.createElement('li');
        li.className = `warning-row warning-${issue.kind}`;
        const icon = ICONS[issue.kind] ?? ICONS.limit;
        li.innerHTML = `${icon}<span></span>`;
        li.querySelector('span').textContent = issue.message;
        list.append(li);
      }
      warnings.append(list);
    }

    function conditionRow(cond) {
      const tr = document.createElement('tr');
      const limits = cond ? cond.issues.filter((i) => i.kind === 'limit') : [];
      const status = !cond
        ? 'Not computed — fuel burn exceeds fuel on board.'
        : limits.length > 0
          ? `${limits.length} limit${limits.length > 1 ? 's' : ''} exceeded — see above.`
          : 'Within envelope.';
      const cells = cond
        ? [cond.label, fmtLb(cond.weightLb), fmtIn(cond.cgIn), fmtLb(cond.momentInLb), status]
        : ['Landing', '—', '—', '—', status];
      for (const [i, value] of cells.entries()) {
        const cell = document.createElement(i === 0 ? 'th' : 'td');
        if (i === 0) cell.setAttribute('scope', 'row');
        cell.textContent = value;
        if (i === 4 && cond && limits.length > 0) cell.className = 'status-bad';
        if (i === 4 && !cond) cell.className = 'status-bad';
        tr.append(cell);
      }
      return tr;
    }

    function renderTables(result) {
      conditionsBody.replaceChildren(
        conditionRow(result.zeroFuel),
        conditionRow(result.takeoff),
        result.landing ? conditionRow(result.landing) : conditionRow(null),
      );

      stationsBody.replaceChildren();
      for (const row of result.rows) {
        const tr = document.createElement('tr');
        const th = document.createElement('th');
        th.setAttribute('scope', 'row');
        th.textContent = row.label;
        tr.append(th);
        for (const v of [fmtLb(row.weightLb), fmtIn(row.armIn), fmtLb(row.momentInLb)]) {
          const td = document.createElement('td');
          td.textContent = v;
          tr.append(td);
        }
        stationsBody.append(tr);
      }
      const totals = [result.zeroFuel, result.takeoff, ...(result.landing ? [result.landing] : [])];
      for (const cond of totals) {
        const tr = document.createElement('tr');
        tr.className = 'totals-row';
        const th = document.createElement('th');
        th.setAttribute('scope', 'row');
        th.textContent = `Total — ${cond.label.toLowerCase()}`;
        tr.append(th);
        for (const v of [fmtLb(cond.weightLb), fmtIn(cond.cgIn), fmtLb(cond.momentInLb)]) {
          const td = document.createElement('td');
          td.textContent = v;
          tr.append(td);
        }
        stationsBody.append(tr);
      }
    }

    function render() {
      const result = computeWB(profile, readInputs());
      usefulLoad.textContent = fmtLb(result.usefulLoadLb);
      renderWarnings(result);
      renderTables(result);
      drawPoints(result);
    }

    // --- Tank toggle ---
    for (const btn of tankButtons) {
      btn.addEventListener('click', () => {
        state.tankId = btn.dataset.tank;
        for (const b of tankButtons) {
          const selected = b === btn;
          b.classList.toggle('is-selected', selected);
          b.setAttribute('aria-pressed', String(selected));
        }
        const tank = currentTank();
        fuelInput.max = String(tank.usableGal);
        if (num(fuelInput) > tank.usableGal) fuelInput.value = String(tank.usableGal);
        tankReadout.textContent = tank.label;
        render();
      });
    }

    for (const input of [oilInput, fuelInput, burnInput, ...stationInputs]) {
      input.addEventListener('input', render);
    }

    printBtn?.addEventListener('click', () => window.print());

    drawChartBase();
    render();
  }
</script>

