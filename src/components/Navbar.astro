---
import { site } from '@/config/site';

const navItems = [
  { label: 'Researching Flight School', href: '/researching-flight-school/' },
  { label: 'PPL Students', href: '/ppl-students/' },
  { label: 'Journey', href: '/journey/' },
  { label: 'About', href: '/about/' },
];
---

<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2" aria-label="Flight School Friend home">
      <div class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center">
        <span class="text-white font-bold text-xs">FSF</span>
      </div>
      <span class="font-bold text-slate-900 tracking-tight">{site.name}</span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
      {navItems.map((item) => (
        <a href={item.href} class="hover:text-sky-600 transition">{item.label}</a>
      ))}
      <a href="/flight-school-decision-tool/quiz/" class="bg-sky-600 text-white px-5 py-2.5 rounded-lg font-bold hover:bg-sky-700 transition btn-hover shadow-sm">
        Start Here
      </a>
    </div>

    <details class="group md:hidden">
      <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-slate-200 text-slate-700 transition hover:border-sky-300 hover:text-sky-600" aria-label="Open navigation menu">
        <svg class="h-5 w-5 group-open:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path></svg>
        <svg class="hidden h-5 w-5 group-open:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </summary>
      <div class="absolute left-0 right-0 top-16 border-b border-slate-200 bg-white p-4 shadow-xl shadow-slate-200/70">
        <div class="mx-auto flex max-w-6xl flex-col gap-2">
          <a href="/flight-school-decision-tool/quiz/" class="mb-2 w-full rounded-lg bg-sky-600 px-5 py-3 text-center text-sm font-bold text-white shadow-sm transition hover:bg-sky-700">
            Start Here
          </a>
          {navItems.map((item) => (
            <a href={item.href} class="rounded-lg px-3 py-3 text-sm font-semibold text-slate-700 transition hover:bg-sky-50 hover:text-sky-700">{item.label}</a>
          ))}
        </div>
      </div>
    </details>
  </div>
</nav>
