---
interface HiddenField {
  name: string;
  value?: string;
  dynamic?: 'source_page' | 'utm_source' | 'utm_medium' | 'utm_campaign';
}

interface Props {
  id: string;
  heading: string;
  body?: string;
  buttonLabel: string;
  microcopy?: string;
  theme?: 'light' | 'dark';
  hiddenFields?: HiddenField[];
}

const {
  id,
  heading,
  body,
  buttonLabel,
  microcopy,
  theme = 'light',
  hiddenFields = [],
} = Astro.props;

const kitFormId = '9565964';
const kitFormAction = `https://app.kit.com/forms/${kitFormId}/subscriptions`;
const iframeName = `kit-capture-${id}`;
const isDark = theme === 'dark';
---

<section class={isDark ? 'rounded-3xl bg-slate-950 p-6 text-white md:p-10' : 'rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-10'}>
  <div class="mx-auto max-w-3xl text-center">
    <h2 class={isDark ? 'text-2xl font-extrabold text-white md:text-3xl' : 'text-2xl font-extrabold text-slate-900 md:text-3xl'}>{heading}</h2>
    {body && <p class={isDark ? 'mx-auto mt-3 max-w-2xl text-sm leading-6 text-slate-300 md:text-base' : 'mx-auto mt-3 max-w-2xl text-sm leading-6 text-slate-600 md:text-base'}>{body}</p>}
  </div>

  <form
    class="fsf-kit-capture mx-auto mt-6 flex max-w-2xl flex-col gap-3 sm:flex-row sm:flex-wrap"
    action={kitFormAction}
    method="post"
    target={iframeName}
    data-capture-id={id}
  >
    <label class="sr-only" for={`email-${id}`}>Email address</label>
    <input
      id={`email-${id}`}
      name="email_address"
      type="email"
      autocomplete="email"
      required
      placeholder="you@example.com"
      class="h-12 w-full min-w-0 rounded-lg border border-slate-200 bg-white px-4 text-sm font-medium text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-sky-300 focus:ring-4 focus:ring-sky-300/25 sm:w-auto sm:min-w-[16rem] sm:flex-1"
    />
    {hiddenFields.map((field) => (
      <input type="hidden" name={field.name} value={field.value ?? ''} data-kit-field={field.dynamic} />
    ))}
    <button
      type="submit"
      class="btn-hover h-12 w-full rounded-lg bg-sky-600 px-5 text-sm font-extrabold text-white transition hover:bg-sky-500 focus:outline-none focus:ring-4 focus:ring-sky-300/30 disabled:cursor-not-allowed disabled:opacity-70 sm:w-auto"
    >
      {buttonLabel}
    </button>
  </form>

  {microcopy && <p class={isDark ? 'mt-4 text-center text-xs font-medium text-slate-400' : 'mt-4 text-center text-xs font-medium text-slate-500'}>{microcopy}</p>}
  <iframe class="hidden" name={iframeName} title={`${heading} signup response`}></iframe>
  <p class="fsf-kit-capture-message mx-auto mt-4 hidden max-w-2xl rounded-lg px-4 py-3 text-center text-sm font-semibold" aria-live="polite"></p>
</section>

<script>
  type DataLayerWindow = Window & {
    dataLayer?: Array<Record<string, unknown>>;
  };

  const setKitMessage = (form: HTMLFormElement, message: string, kind: 'success' | 'error') => {
    const panel = form.closest('section');
    const messageEl = panel?.querySelector<HTMLParagraphElement>('.fsf-kit-capture-message');

    if (!messageEl) return;

    messageEl.textContent = message;
    messageEl.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-900', 'bg-red-50', 'text-red-900');
    messageEl.classList.add(
      kind === 'success' ? 'bg-emerald-50' : 'bg-red-50',
      kind === 'success' ? 'text-emerald-900' : 'text-red-900',
    );
  };

  document.querySelectorAll<HTMLFormElement>('.fsf-kit-capture').forEach((form) => {
    form.addEventListener('submit', (event) => {
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const formData = new FormData(form);
      const email = String(formData.get('email_address') || '').trim();
      const urlParams = new URLSearchParams(window.location.search);

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        event.preventDefault();
        setKitMessage(form, 'Enter a valid email address.', 'error');
        return;
      }

      form.querySelector<HTMLInputElement>('[data-kit-field="source_page"]')?.setAttribute('value', window.location.pathname);
      form.querySelector<HTMLInputElement>('[data-kit-field="utm_source"]')?.setAttribute('value', urlParams.get('utm_source') || '');
      form.querySelector<HTMLInputElement>('[data-kit-field="utm_medium"]')?.setAttribute('value', urlParams.get('utm_medium') || '');
      form.querySelector<HTMLInputElement>('[data-kit-field="utm_campaign"]')?.setAttribute('value', urlParams.get('utm_campaign') || '');

      const dataWindow = window as DataLayerWindow;
      dataWindow.dataLayer?.push({
        event: 'fsf_kit_capture_submit',
        captureId: form.dataset.captureId || '',
      });

      const originalButtonText = button?.textContent || 'Subscribe';
      button?.setAttribute('disabled', 'true');
      if (button) button.textContent = 'Sending...';

      window.setTimeout(() => {
        form.reset();
        setKitMessage(form, 'Check your inbox. You are on the list.', 'success');
        dataWindow.dataLayer?.push({
          event: 'fsf_kit_capture_success',
          captureId: form.dataset.captureId || '',
        });
        button?.removeAttribute('disabled');
        if (button) button.textContent = originalButtonText;
      }, 900);
    });
  });
</script>
