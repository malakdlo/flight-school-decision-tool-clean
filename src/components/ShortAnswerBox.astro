---
interface Props {
  heading?: string;
}

const { heading = 'Short answer' } = Astro.props;
---

<div class="rounded-r-2xl border-l-4 border-sky-500 bg-slate-50 p-6 shadow-sm">
  <h2 class="mb-2 text-lg font-bold text-slate-900">{heading}</h2>
  <p class="font-medium leading-7 text-slate-700"><slot /></p>
</div>
