---
const steps = ['Start', 'Solo', 'PPL', 'Instrument', 'Commercial'];
---

<div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
  <h3 class="mb-8 text-xl font-bold text-slate-900">Roadmap Preview</h3>
  <div class="relative">
    <div class="absolute top-5 left-0 h-1 w-full rounded-full bg-slate-200"></div>
    <div class="absolute top-5 left-0 h-1 w-3/4 rounded-full bg-sky-600"></div>
    <div class="relative grid grid-cols-5 gap-2">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center">
          <div class={`mb-3 flex h-11 w-11 items-center justify-center rounded-full text-sm font-bold ${index < 4 ? 'bg-sky-600 text-white' : 'bg-white text-slate-500 border border-slate-200'}`}>
            {index + 1}
          </div>
          <span class="text-xs font-bold text-slate-500">{step}</span>
        </div>
      ))}
    </div>
  </div>
</div>
