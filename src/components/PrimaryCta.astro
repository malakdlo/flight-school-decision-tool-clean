---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'dark';
}

const { href, variant = 'primary' } = Astro.props;

const classes = {
  primary: 'bg-sky-600 text-white hover:bg-sky-700',
  secondary: 'bg-white text-slate-700 border border-slate-200',
  dark: 'bg-slate-900 text-white hover:bg-slate-800',
};
---

<a href={href} class={`btn-hover inline-flex items-center justify-center rounded-xl px-8 py-4 text-lg font-bold ${classes[variant]}`}>
  <slot />
</a>
