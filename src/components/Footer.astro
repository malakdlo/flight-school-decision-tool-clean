---
import { site } from '@/config/site';
import KitCapture from '@/components/KitCapture.astro';
---

<footer class="mt-auto border-t border-slate-200 bg-white pt-16 pb-8">
  <div class="mx-auto mb-12 grid max-w-6xl grid-cols-1 gap-8 px-4 md:grid-cols-3 lg:grid-cols-[1.1fr_.8fr_.8fr_1.5fr]">
    <div class="md:col-span-3 lg:col-span-1">
      <a href="/" class="mb-5 flex items-center gap-2" aria-label="Flight School Friend home">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-900">
          <span class="text-xs font-bold text-white">FSF</span>
        </div>
        <span class="font-bold tracking-tight text-slate-900">{site.name}</span>
      </a>
      <p class="mb-4 text-sm leading-6 text-slate-500">A friend for every leg of the flight school journey.</p>
      <a href="https://www.instagram.com/privatepilotnotebook/" target="_blank" rel="noopener" class="mb-5 inline-block text-sm font-bold text-sky-700 hover:underline">@privatepilotnotebook</a>
      <p class="text-xs leading-5 text-slate-400">Independent decision support — not flight instruction, legal, medical, or financial advice.</p>
    </div>

    <div>
      <h5 class="mb-4 font-bold text-slate-900">Explore</h5>
      <ul class="space-y-3 text-sm text-slate-500">
        <li><a href="/researching-flight-school/" class="transition hover:text-sky-600">Researching Flight School</a></li>
        <li><a href="/ppl-students/" class="transition hover:text-sky-600">PPL Students</a></li>
        <li><a href="/journey/" class="transition hover:text-sky-600">Journey</a></li>
        <li><a href="/about/" class="transition hover:text-sky-600">About</a></li>
      </ul>
    </div>

    <div>
      <h5 class="mb-4 font-bold text-slate-900">Tools</h5>
      <ul class="space-y-3 text-sm text-slate-500">
        <li><a href="/flight-school-decision-tool/quiz/" class="transition hover:text-sky-600">Decision Quiz</a></li>
        <li><a href="/tools/flight-school-cost-calculator/" class="transition hover:text-sky-600">Cost Calculator</a></li>
        <li><a href="/tools/" class="transition hover:text-sky-600">All Tools</a></li>
        <li><a href="/guides/" class="transition hover:text-sky-600">All Guides</a></li>
      </ul>
    </div>

    <div>
      <KitCapture
        id="footer-newsletter"
        heading="Get the tools as I build them"
        body="New calculators, checklists, and flight-by-flight lessons — free."
        buttonLabel="Subscribe"
        microcopy="No spam. Unsubscribe anytime."
        hiddenFields={[
          { name: 'fields[source_page]', dynamic: 'source_page' },
          { name: 'fields[utm_source]', dynamic: 'utm_source' },
          { name: 'fields[utm_medium]', dynamic: 'utm_medium' },
          { name: 'fields[utm_campaign]', dynamic: 'utm_campaign' },
        ]}
      />
    </div>
  </div>

  <div class="mx-auto flex max-w-6xl flex-col gap-3 border-t border-slate-100 px-4 pt-8 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
    <p>&copy; 2026 {site.name}. All rights reserved.</p>
    <div class="flex gap-4">
      <a href="/privacy/" class="transition hover:text-sky-600">Privacy Policy</a>
    </div>
  </div>
</footer>
