---
import { site } from '@/config/site';
---

<footer class="border-t border-slate-200 bg-white pt-16 pb-8">
  <div class="mx-auto mb-12 grid max-w-6xl grid-cols-2 gap-8 px-4 md:grid-cols-4">
    <div class="col-span-2">
      <div class="mb-6 flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-900">
          <span class="text-xs font-bold text-white">FS</span>
        </div>
        <span class="font-bold tracking-tight text-slate-900">{site.name}</span>
      </div>
      <p class="max-w-xs text-sm text-slate-500">
        Helping future aviators take flight with confidence, clarity, and realistic expectations.
      </p>
    </div>

    <div>
      <h5 class="mb-4 font-bold text-slate-900">Guides</h5>
      <ul class="space-y-2 text-sm text-slate-500">
        <li><a href="/guides/flight-school-cost/" class="hover:text-sky-600">Cost Breakdown</a></li>
        <li><a href="/guides/" class="hover:text-sky-600">License Types</a></li>
        <li><a href="/guides/" class="hover:text-sky-600">Medical Exams</a></li>
      </ul>
    </div>

    <div>
      <h5 class="mb-4 font-bold text-slate-900">Tools</h5>
      <ul class="space-y-2 text-sm text-slate-500">
        <li><a href="/quiz/" class="hover:text-sky-600">Assessment Quiz</a></li>
        <li><a href="/guides/" class="hover:text-sky-600">Beginner Guides</a></li>
        <li><a href="/quiz/" class="hover:text-sky-600">Starter Kit</a></li>
      </ul>
    </div>
  </div>

  <div class="mx-auto max-w-6xl border-t border-slate-100 px-4 pt-8 text-center text-xs text-slate-400">
    &copy; 2026 Flight School Decision Tool. Clear for takeoff.
  </div>
</footer>
