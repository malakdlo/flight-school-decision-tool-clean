---
import { site } from '@/config/site';
---

<footer class="bg-white border-t border-slate-200 pt-16 pb-8 mt-auto">
  <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-5 gap-8 mb-12">

    <div class="col-span-2 md:col-span-1">
      <a href="/" class="flex items-center gap-2 mb-6" aria-label="Flight School Friend home">
        <div class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-xs">FSF</span>
        </div>
      </a>
      <p class="text-slate-500 text-sm mb-6 pr-4">The independent decision layer for future pilots. Plan your path before you pay.</p>
      <a href="/flight-school-decision-tool/quiz/" class="inline-block bg-sky-100 text-sky-700 px-4 py-2 rounded font-bold text-sm hover:bg-sky-200 transition">
        Start Here &rarr;
      </a>
    </div>

    <div>
      <h5 class="font-bold text-slate-900 mb-4">Start</h5>
      <ul class="text-sm text-slate-500 space-y-3">
        <li><a href="/flight-school-decision-tool/" class="hover:text-sky-600 transition">Flight School Decision Tool</a></li>
        <li><a href="/flight-school-decision-tool/quiz/" class="hover:text-sky-600 transition">Take the Free Quiz</a></li>
        <li><a href="/guides/" class="hover:text-sky-600 transition">Flight School Starter Guides</a></li>
      </ul>
    </div>

    <div>
      <h5 class="font-bold text-slate-900 mb-4">Guides</h5>
      <ul class="text-sm text-slate-500 space-y-3">
        <li><a href="/guides/flight-school-cost/" class="hover:text-sky-600 transition">Flight School Cost</a></li>
        <li><a href="/guides/part-61-vs-part-141/" class="hover:text-sky-600 transition">Part 61 vs Part 141</a></li>
        <li><a href="/guides/how-to-choose-a-flight-school/" class="hover:text-sky-600 transition">How to Choose a Flight School</a></li>
        <li><a href="/guides/private-pilot-requirements/" class="hover:text-sky-600 transition">Private Pilot Requirements</a></li>
      </ul>
    </div>

    <div>
      <h5 class="font-bold text-slate-900 mb-4">Future Resources</h5>
      <ul class="text-sm text-slate-500 space-y-3">
        <li><a href="/tools/" class="hover:text-sky-600 transition text-slate-400">Tools</a></li>
        <li><a href="/find/" class="hover:text-sky-600 transition text-slate-400">Find Resources</a></li>
      </ul>
    </div>

    <div>
      <h5 class="font-bold text-slate-900 mb-4">Company</h5>
      <ul class="text-sm text-slate-500 space-y-3">
        <li><a href="/about/" class="hover:text-sky-600 transition">About</a></li>
        <li><a href="/privacy/" class="hover:text-sky-600 transition">Privacy Policy</a></li>
      </ul>
    </div>

  </div>

  <div class="max-w-6xl mx-auto px-4 border-t border-slate-100 pt-8 text-center md:text-left">
    <p class="text-sm text-slate-400">&copy; 2026 {site.name}. All rights reserved.</p>
  </div>
</footer>
